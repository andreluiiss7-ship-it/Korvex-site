---
import { waUrl, REGISTER_URL } from '../lib/site';
import { icon } from '../lib/icons';

const pills = [
  { label: 'Saque D0 no Pix' },
  { label: 'Saque em cripto' },
  { label: '135+ moedas' },
  { label: 'Upsell one-click' },
  { label: 'Checkout sob medida' },
];

const stats = [
  { big: 'R$ 129M+', label: 'transacionados' },
  { big: '400+',     label: 'players ativos' },
  { big: '94%',      label: 'aprovação no cartão' },
  { big: '99,9%',    label: 'uptime no pico' },
];
---

<section id="topo" class="relative overflow-hidden pt-28 pb-16 sm:pt-32 sm:pb-20">
  <!-- atmosphere -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-grid-faint [background-size:48px_48px] opacity-50 [mask-image:radial-gradient(ellipse_72%_55%_at_50%_30%,#000_25%,transparent_72%)]"></div>
    <div data-parallax="0.12" class="ambient-drift absolute right-[10%] top-[-10%] h-[480px] w-[680px] rounded-full bg-[radial-gradient(circle,rgba(59,130,246,0.20),transparent_60%)] blur-2xl"></div>
    <div data-parallax="0.08" class="absolute left-[-5%] bottom-[10%] h-[360px] w-[480px] rounded-full bg-[radial-gradient(circle,rgba(201,163,94,0.07),transparent_60%)] blur-3xl"></div>
    <!-- subtle network constellation behind the centered copy -->
    <svg class="absolute left-1/2 top-[8%] -translate-x-1/2 hidden h-[560px] w-[1100px] opacity-[0.18] lg:block" viewBox="0 0 1100 560" fill="none" aria-hidden="true">
      <g stroke="rgba(111,160,255,0.5)" stroke-width="0.5">
        <line x1="180" y1="120" x2="360" y2="180"/>
        <line x1="360" y1="180" x2="540" y2="100"/>
        <line x1="540" y1="100" x2="720" y2="180"/>
        <line x1="720" y1="180" x2="900" y2="120"/>
        <line x1="180" y1="120" x2="280" y2="320"/>
        <line x1="360" y1="180" x2="540" y2="380"/>
        <line x1="540" y1="100" x2="540" y2="380"/>
        <line x1="720" y1="180" x2="820" y2="380"/>
        <line x1="900" y1="120" x2="820" y2="380"/>
      </g>
      <g fill="#6FA0FF">
        <circle cx="180" cy="120" r="2"><animate attributeName="opacity" values="0.3;1;0.3" dur="3s" repeatCount="indefinite"/></circle>
        <circle cx="360" cy="180" r="2"><animate attributeName="opacity" values="1;0.3;1" dur="3.4s" repeatCount="indefinite"/></circle>
        <circle cx="540" cy="100" r="2.5"><animate attributeName="opacity" values="0.5;1;0.5" dur="2.6s" repeatCount="indefinite"/></circle>
        <circle cx="720" cy="180" r="2"><animate attributeName="opacity" values="0.4;1;0.4" dur="2.2s" repeatCount="indefinite"/></circle>
        <circle cx="900" cy="120" r="2"><animate attributeName="opacity" values="1;0.4;1" dur="2.8s" repeatCount="indefinite"/></circle>
        <circle cx="280" cy="320" r="2"><animate attributeName="opacity" values="0.6;1;0.6" dur="3.2s" repeatCount="indefinite"/></circle>
        <circle cx="540" cy="380" r="2"><animate attributeName="opacity" values="0.3;0.9;0.3" dur="3.6s" repeatCount="indefinite"/></circle>
        <circle cx="820" cy="380" r="2"><animate attributeName="opacity" values="0.7;0.3;0.7" dur="2.4s" repeatCount="indefinite"/></circle>
      </g>
    </svg>
  </div>

  <div class="section flex flex-col items-center text-center">
    <!-- Eyebrow -->
    <div class="reveal inline-flex items-center gap-2.5 text-[10px] font-mono sm:text-[11px]" style="letter-spacing:0.22em;text-transform:uppercase;color:var(--blue-2);">
      <span class="inline-block h-1.5 w-1.5 flex-none rounded-full bg-[--blue] shadow-[0_0_14px_var(--blue-glow)]"></span>
      <span class="sm:hidden">Korvex · Gateway de alto faturamento</span>
      <span class="hidden sm:inline">Korvex · Gateway para operações de alto faturamento</span>
    </div>

    <!-- Headline — manifesto, Korvex no centro -->
    <h1 class="reveal mt-7 max-w-4xl font-display text-[2.6rem] font-extrabold leading-[0.98] tracking-[-0.045em] text-white sm:text-[4.4rem]">
      A Korvex não joga o jogo deles.
      <span class="block font-editorial italic font-normal text-titan-gradient">Joga o seu.</span>
    </h1>

    <!-- Lead -->
    <p class="reveal mt-6 max-w-2xl text-pretty text-[1.05rem] leading-relaxed text-chrome-300/80 sm:text-[1.1rem]">
      Antecipação. Reserva. Chargeback. Spread. Cada nome, um pedaço seu virando lucro de plataforma.
      <strong class="text-white">A Korvex é o primeiro gateway construído contra esse modelo — e pelo lado de quem vende.</strong>
      Saque D0. Taxa 6,99% real. Gerente humano. Por infoprodutor, pra infoprodutor.
    </p>

    <!-- CTAs persona-routing -->
    <div class="reveal mt-9 grid w-full max-w-3xl gap-3 sm:grid-cols-2">
      <a href={waUrl('Olá! Faturando R$100K+/mês — quero análise da operação na Korvex.')} target="_blank" rel="noopener" class="persona-cta primary group">
        <span class="persona-q">Faturando R$ 100K+ / mês?</span>
        <span class="persona-a">
          Falar com especialista
          <small>· resposta em 1h</small>
          <span class="h-4 w-4" set:html={icon('arrow')}></span>
        </span>
      </a>
      <a href={REGISTER_URL} target="_blank" rel="noopener" class="persona-cta ghost group">
        <span class="persona-q">Começando ou validando?</span>
        <span class="persona-a">
          Criar conta agora
          <span class="h-4 w-4" set:html={icon('arrow')}></span>
        </span>
      </a>
    </div>


    <!-- Pills -->
    <div class="reveal mt-8 mx-auto flex max-w-md flex-wrap justify-center gap-2 sm:max-w-none">
      {pills.map((p) => (
        <span class="inline-flex items-center gap-2 rounded-full border border-suede-500/20 bg-white/[0.025] px-3 py-1.5 text-[12.5px] font-medium text-chrome-200">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-[--blue] shadow-[0_0_8px_var(--blue-glow)]"></span>
          {p.label}
        </span>
      ))}
    </div>

    <!-- Inline stats — grid 2x2 no mobile (balanceado), flex no desktop -->
    <div class="reveal mt-10 grid grid-cols-2 gap-x-6 gap-y-4 border-t border-suede-500/10 pt-5 sm:mt-12 sm:flex sm:flex-wrap sm:items-center sm:justify-center sm:gap-x-7 sm:pt-6">
      {stats.map((s, i) => (
        <>
          {i > 0 && <span class="hidden h-4 w-px bg-suede-500/15 sm:block"></span>}
          <div class="inline-flex items-baseline justify-center gap-1.5">
            <span class="font-display text-base font-bold leading-none text-white sm:text-lg" style="font-feature-settings:'tnum';">{s.big}</span>
            <span class="font-mono text-[9px] uppercase tracking-[0.14em] text-chrome-300/55 sm:text-[10px]">{s.label}</span>
          </div>
        </>
      ))}
    </div>
  </div>
</section>


<style>
  .persona-cta {
    display: flex; flex-direction: column; gap: 6px;
    padding: 14px 18px;
    border-radius: 16px;
    text-align: left;
    transition: all .2s ease;
    position: relative;
    overflow: hidden;
  }
  .persona-cta.primary {
    background: linear-gradient(180deg, #2B5FA0, #1A3A6B);
    border: 1px solid rgba(168,204,255,0.35);
    color: #fff;
    box-shadow: 0 1px 0 rgba(255,255,255,0.18) inset, 0 14px 32px -10px rgba(43,95,160,0.55);
  }
  .persona-cta.primary:hover { transform: translateY(-1px); box-shadow: 0 1px 0 rgba(255,255,255,0.22) inset, 0 18px 38px -10px rgba(43,95,160,0.7); }
  .persona-cta.ghost {
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(184,176,160,0.18);
    color: #fff;
  }
  .persona-cta.ghost:hover { background: rgba(255,255,255,0.05); border-color: rgba(184,176,160,0.3); }
  .persona-q {
    font-family: 'Geist Mono', monospace;
    font-size: 10.5px; font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
  }
  .persona-cta.ghost .persona-q { color: rgba(176,179,184,0.65); }
  .persona-a {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: 'Geist', sans-serif;
    font-size: 16px; font-weight: 700;
    color: #fff;
  }
  .persona-a small { font-weight: 400; opacity: 0.7; font-size: 12px; }
  .persona-cta .h-4 { transition: transform .2s ease; }
  .persona-cta:hover .h-4 { transform: translateX(3px); }
</style>
