---
import { WHATSAPP_URL, waUrl, REGISTER_URL } from '../lib/site';
import { icon } from '../lib/icons';

const pills = [
  { icon: 'bolt', label: 'Saque D0 no Pix' },
  { icon: 'globe', label: '135+ moedas' },
  { icon: 'cursor', label: 'Upsell one-click' },
  { icon: 'paint', label: 'Checkout sob medida' },
];

const feed = [
  { m: 'Pix', v: 'R$ 1.997,00', t: 'aprovado · agora' },
  { m: 'Cartão', v: 'USD 1.200,00', t: 'internacional' },
  { m: 'Pix', v: 'R$ 6.420,00', t: 'sacado D0' },
];
---

<section class="relative overflow-hidden pt-36 pb-24 sm:pt-44 sm:pb-32">
  <!-- atmosphere -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-grid-faint [background-size:56px_56px] opacity-50 [mask-image:radial-gradient(ellipse_72%_55%_at_50%_0%,#000_25%,transparent_72%)]"></div>
    <div class="absolute left-1/2 top-[-14%] h-[560px] w-[920px] -translate-x-1/2 rounded-full bg-titan-600/20 blur-[130px]"></div>
    <div class="absolute right-[-8%] top-[34%] h-[380px] w-[380px] rounded-full bg-gold-600/[0.06] blur-[120px]"></div>
  </div>

  <div data-tilt-zone class="section grid items-center gap-14 lg:grid-cols-[1.04fr_0.96fr]">
    <!-- LEFT -->
    <div>
      <div class="reveal inline-flex items-center gap-2.5 rounded-full border border-suede-500/20 bg-white/[0.03] py-1.5 pl-1.5 pr-4">
        <span class="inline-flex items-center gap-1.5 rounded-full bg-titan-600/20 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-titan-300">
          <span class="h-1.5 w-1.5 rounded-full bg-titan-400 shadow-[0_0_10px_2px_rgba(111,163,224,0.9)]"></span> Korvex
        </span>
        <span class="text-[12px] font-medium text-chrome-300/75">Gateway para operações de alto faturamento</span>
      </div>

      <h1 class="reveal mt-7 font-display text-[2.7rem] font-bold leading-[1.02] tracking-tight text-white sm:text-[4.1rem]">
        O gateway que opera<br class="hidden sm:block" /> no <span class="text-titan-gradient">seu nível.</span>
      </h1>

      <p class="reveal mt-6 max-w-xl text-pretty text-[1.08rem] leading-relaxed text-chrome-300/80">
        Para infoprodutores, experts, lançadores e coprodutores que já faturam: saque no mesmo dia,
        checkout que converte, funil com upsell e venda em 135+ moedas. A infraestrutura de quem não pode parar.
      </p>

      <div class="reveal mt-9 flex flex-wrap items-center gap-3">
        <a href={REGISTER_URL} target="_blank" rel="noopener" class="btn btn-primary magnetic !px-7 !py-3.5">
          Criar minha conta na Korvex
          <span class="h-4 w-4" set:html={icon('arrow')}></span>
        </a>
        <a href={waUrl('Olá! Quero solicitar uma análise da minha operação para a Korvex.')} target="_blank" rel="noopener" class="btn btn-ghost !px-6 !py-3.5">
          Falar com um especialista
        </a>
      </div>

      <div class="reveal mt-9 flex flex-wrap gap-2.5">
        {pills.map((p) => (
          <span class="inline-flex items-center gap-2 rounded-full border border-suede-500/20 bg-white/[0.03] px-3.5 py-2 text-[13px] font-medium text-chrome-200">
            <span class="inline-block h-4 w-4 text-titan-400" set:html={icon(p.icon)} />
            {p.label}
          </span>
        ))}
      </div>

      <!-- inline stat bar (editorial, não 4 cards iguais) -->
      <div class="reveal mt-10 flex flex-wrap items-center gap-x-8 gap-y-3 border-t border-suede-500/12 pt-7">
        <div class="flex items-baseline gap-2">
          <span class="font-display text-2xl font-bold text-white">R$129M<span class="text-suede-400">+</span></span>
          <span class="text-[12px] text-chrome-300/55">transacionados</span>
        </div>
        <div class="h-8 w-px bg-suede-500/15"></div>
        <div class="flex items-baseline gap-2">
          <span class="font-display text-2xl font-bold text-white">400<span class="text-suede-400">+</span></span>
          <span class="text-[12px] text-chrome-300/55">players ativos</span>
        </div>
        <div class="h-8 w-px bg-suede-500/15"></div>
        <div class="flex items-baseline gap-2">
          <span class="font-display text-2xl font-bold text-white">94%</span>
          <span class="text-[12px] text-chrome-300/55">aprovação no cartão</span>
        </div>
      </div>
    </div>

    <!-- RIGHT: tilted dashboard + live feed -->
    <div class="reveal relative">
      <div class="absolute -inset-8 -z-10 rounded-[32px] bg-gradient-to-tr from-titan-600/25 via-transparent to-gold-600/10 blur-3xl"></div>

      <div data-tilt="5" class="tilt beam relative rounded-2xl">
        <div class="browser">
          <div class="browser-bar">
            <span class="dot bg-[#ff5f57]/80"></span>
            <span class="dot bg-[#febc2e]/80"></span>
            <span class="dot bg-[#28c840]/80"></span>
            <span class="ml-3 flex items-center gap-1.5 rounded-md bg-white/5 px-2.5 py-1 text-[11px] text-chrome-300/70">
              <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 1 1 8 0v4"/></svg>
              app.korvex.com.br
            </span>
          </div>
          <img src="/assets/dashboard.png" alt="Painel Korvex — saldo, conquistas e vendas por método" class="block w-full" loading="eager" />
        </div>
      </div>

      <!-- live approvals feed -->
      <div class="absolute -right-3 top-6 hidden w-52 sm:block">
        <div class="rounded-2xl border border-suede-500/25 bg-ink/90 p-3 shadow-glow backdrop-blur-xl">
          <div class="mb-2 flex items-center justify-between">
            <span class="text-[10px] font-semibold uppercase tracking-wider text-chrome-300/55">Aprovações</span>
            <span class="inline-flex items-center gap-1 text-[10px] font-semibold text-emerald-400"><span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>ao vivo</span>
          </div>
          <div class="space-y-1.5">
            {feed.map((f, i) => (
              <div class="feed-item flex items-center justify-between rounded-lg border border-suede-500/12 bg-white/[0.02] px-2.5 py-1.5" style={`animation-delay:${i * 1.4}s`}>
                <div>
                  <p class="text-[11px] font-semibold text-white">{f.v}</p>
                  <p class="text-[9px] text-chrome-300/55">{f.m} · {f.t}</p>
                </div>
                <span class="flex h-5 w-5 items-center justify-center rounded-full bg-emerald-500/15 text-emerald-400"><svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m4 12 5 5L20 6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- floating saque card -->
      <div class="absolute -bottom-5 -left-4 hidden w-52 rounded-2xl border border-suede-500/25 bg-ink/90 p-4 shadow-glow backdrop-blur-xl sm:block">
        <p class="text-[11px] uppercase tracking-wider text-chrome-300/55">Saque realizado</p>
        <p class="mt-1 font-display text-2xl font-bold text-white">R$113.478<span class="text-suede-400">,27</span></p>
        <p class="mt-1 text-[11px] text-titan-400">Pix · mesmo dia (D0)</p>
      </div>
    </div>
  </div>
</section>
