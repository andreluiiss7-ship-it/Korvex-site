---
import { REGISTER_URL } from '../lib/site';
import { icon } from '../lib/icons';
---

<section id="calculadora" class="relative py-24 sm:py-28">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute inset-0" style="background: radial-gradient(700px 420px at 80% 30%, rgba(59,130,246,0.10), transparent 60%);"></div>
  </div>

  <div class="section">
    <div class="reveal mx-auto max-w-5xl">
      <div class="grid gap-8 rounded-[36px] border border-titan-500/30 bg-gradient-to-br from-titan-600/10 via-ink to-ink p-7 shadow-glow sm:p-12 lg:grid-cols-[1.05fr_1fr]">

        <!-- LEFT: copy + slider -->
        <div>
          <span class="kicker">A conta na sua frente</span>
          <h2 class="h-display mt-4 text-3xl leading-[1.04] sm:text-[2.6rem]">
            Quanto você está
            <span class="font-display font-black text-chrome-300/65">doando</span>
            por mês?
          </h2>
          <p class="mt-4 max-w-md text-[15px] leading-relaxed text-chrome-300/72">
            Arrasta pra ver a conta real. Considerando custo efetivo de gateway tradicional:
            <b class="text-white">~12%</b> (taxa visível 4,99% + antecipação + reserva + chargeback fee + spread).
          </p>

          <div class="mt-8">
            <label class="text-[11px] font-bold uppercase tracking-[0.18em] text-chrome-300/55 font-mono">Seu faturamento mensal</label>
            <div class="mt-3 flex items-baseline gap-2">
              <span class="font-display text-3xl font-bold text-white sm:text-4xl" id="calc-rev" style="font-feature-settings:'tnum';">R$ 300.000</span>
              <span class="text-xs text-chrome-300/55">/mês</span>
            </div>
            <input id="calc-slider" type="range" min="50000" max="2000000" step="10000" value="300000" class="calc-slider mt-5 w-full" aria-label="Faturamento mensal" />
            <div class="mt-1.5 flex justify-between text-[10px] text-chrome-300/40 font-mono">
              <span>R$ 50K</span>
              <span>R$ 1MM</span>
              <span>R$ 2MM</span>
            </div>
          </div>
        </div>

        <!-- RIGHT: result -->
        <div class="rounded-[24px] border border-suede-500/15 bg-white/[0.02] p-6 sm:p-8">
          <div>
            <p class="text-[10.5px] font-bold uppercase tracking-[0.18em] text-chrome-300/55 font-mono">
              <span class="inline-block h-1 w-1 align-middle rounded-full bg-chrome-300/50"></span>
              Hoje você está doando
            </p>
            <p class="mt-2 font-display text-[40px] font-bold leading-none text-chrome-300/85 sm:text-[44px]" id="calc-loss" style="font-feature-settings:'tnum';">R$ 36.000</p>
            <p class="mt-1 text-[12px] text-chrome-300/55">/mês pra plataforma "famosa"</p>
          </div>

          <div class="my-5 h-px bg-suede-500/12"></div>

          <div>
            <p class="text-[10.5px] font-bold uppercase tracking-[0.18em] text-titan-300 font-mono">
              <span class="inline-block h-1 w-1 align-middle rounded-full bg-titan-400"></span>
              Com a Korvex, fica
            </p>
            <p class="mt-2 font-display text-[40px] font-bold leading-none text-titan-gradient sm:text-[44px]" id="calc-save" style="font-feature-settings:'tnum';">+R$ 15.000</p>
            <p class="mt-1 text-[12px] text-chrome-300/55">/mês de volta no seu caixa</p>
          </div>

          <div class="mt-6 rounded-2xl border border-titan-500/25 bg-titan-600/10 p-4">
            <p class="text-[10.5px] font-bold uppercase tracking-[0.18em] text-titan-300/85 font-mono">Economia em 12 meses</p>
            <p class="mt-1.5 font-display text-2xl font-bold leading-tight text-white sm:text-[26px]" id="calc-year" style="font-feature-settings:'tnum';">R$ 180.000 a mais no seu bolso</p>
          </div>

          <a href={REGISTER_URL} target="_blank" rel="noopener" class="btn btn-primary magnetic mt-6 w-full justify-center !py-3.5">
            Quero essa economia agora
            <span class="h-4 w-4" set:html={icon('arrow')}></span>
          </a>
          <p class="mt-3 text-center text-[11px] text-chrome-300/50">Cálculo conservador. Negociável pra +R$500K/mês.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const slider = document.getElementById('calc-slider');
    const rev = document.getElementById('calc-rev');
    const loss = document.getElementById('calc-loss');
    const save = document.getElementById('calc-save');
    const year = document.getElementById('calc-year');
    if (!slider) return;
    const fmt = (n) => 'R$ ' + n.toLocaleString('pt-BR', { maximumFractionDigits: 0 });
    const COMPETITOR = 0.12;
    const KORVEX = 0.07;
    const update = () => {
      const r = parseFloat(slider.value);
      const lossM = r * COMPETITOR;
      const saveM = r * (COMPETITOR - KORVEX);
      const yearTotal = saveM * 12;
      rev.textContent = fmt(r);
      loss.textContent = fmt(lossM);
      save.textContent = '+' + fmt(saveM);
      year.textContent = fmt(yearTotal) + ' a mais no seu bolso';
    };
    slider.addEventListener('input', update);
    update();
  })();
</script>

<style>
  .calc-slider {
    -webkit-appearance: none;
    appearance: none;
    height: 6px;
    background: linear-gradient(to right, rgba(111,160,255,0.45), rgba(111,160,255,1));
    border-radius: 999px;
    outline: none;
  }
  .calc-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 24px; height: 24px;
    border-radius: 50%;
    background: #fff;
    border: 3px solid #6FA3E0;
    cursor: grab;
    box-shadow: 0 6px 16px rgba(0,0,0,0.45), 0 0 0 5px rgba(111,160,255,0.18);
    transition: transform .15s ease;
  }
  .calc-slider::-webkit-slider-thumb:active { cursor: grabbing; transform: scale(1.1); }
  .calc-slider::-moz-range-thumb {
    width: 24px; height: 24px;
    border-radius: 50%;
    background: #fff;
    border: 3px solid #6FA3E0;
    cursor: grab;
  }
</style>
