---
import { icon } from '../lib/icons';
import { REGISTER_URL } from '../lib/site';

const ladder = [
  { milestone: 'R$10 mil', reward: 'Pulseira Korvex', img: '/assets/pulseira-10k.png', note: 'O primeiro marco. Sua entrada no jogo sério.', tone: 'titan' },
  { milestone: 'R$100 mil', reward: 'Placa 100K', img: '/assets/placa-100k.jpg', note: 'Reconhecimento de quem chegou com consistência.', tone: 'titan' },
  { milestone: 'R$500 mil', reward: 'Placa 500K', img: '/assets/placa-500k.jpg', note: 'Para quem virou operação e opera no controle.', tone: 'titan' },
];
const steps = ['R$10K', 'R$100K', 'R$500K', 'R$1MM'];
---

<section id="premiacoes" class="relative overflow-hidden py-24 sm:py-32">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute left-1/2 top-1/2 h-[560px] w-[900px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-gold-600/[0.07] blur-[150px]"></div>
    <div class="absolute inset-0 bg-grid-faint [background-size:64px_64px] opacity-25 vignette"></div>
  </div>

  <div class="section">
    <!-- header -->
    <div class="reveal mx-auto max-w-2xl text-center">
      <span class="kicker justify-center">Reconhecimento</span>
      <h2 class="h-display mt-6 text-4xl leading-[1.05] sm:text-5xl">
        Aqui, faturamento alto <span class="text-gold-gradient">vira troféu na parede.</span>
      </h2>
      <p class="mx-auto mt-5 max-w-xl text-pretty text-lg leading-relaxed text-chrome-300/70">
        Cada marco da sua operação é reconhecido de verdade — em metal, não em e-mail automático.
      </p>
    </div>

    <!-- progress ladder -->
    <div class="reveal mx-auto mt-10 flex max-w-2xl items-center gap-2">
      {steps.map((s, i) => (
        <>
          <div class={`flex items-center gap-2 ${i === 3 ? 'text-gold-300' : 'text-chrome-200'}`}>
            <span class={`flex h-7 w-7 items-center justify-center rounded-full text-[11px] font-bold ${i === 3 ? 'bg-gold-600/20 text-gold-300 ring-1 ring-gold-600/40' : 'bg-titan-600/15 text-titan-300'}`}>{i + 1}</span>
            <span class="text-[12px] font-semibold">{s}</span>
          </div>
          {i < steps.length - 1 && <span class={`h-px flex-1 ${i < 2 ? 'bg-titan-500/30' : 'bg-gradient-to-r from-titan-500/30 to-gold-500/50'}`}></span>}
        </>
      ))}
    </div>

    <!-- ladder cards with pedestal + reflection -->
    <div class="mt-12 grid gap-4 md:grid-cols-3">
      {ladder.map((a, i) => (
        <div class="reveal spotlight card card-hover group relative overflow-hidden p-6 text-center" style={`transition-delay:${i * 70}ms`}>
          <div class="pointer-events-none absolute inset-x-0 top-0 h-40 bg-[radial-gradient(circle_at_50%_-20%,rgba(111,163,224,0.25),transparent_60%)]"></div>
          <div class="relative flex h-48 items-end justify-center">
            <img src={a.img} alt={a.reward} class="relative z-10 max-h-44 w-auto object-contain drop-shadow-[0_24px_30px_rgba(0,0,0,0.65)] transition-transform duration-500 group-hover:-translate-y-1.5" loading="lazy" />
            <!-- reflection -->
            <img src={a.img} alt="" aria-hidden="true" class="absolute bottom-[-38px] left-1/2 max-h-44 w-auto -translate-x-1/2 scale-y-[-1] object-contain opacity-20 blur-[1px] [mask-image:linear-gradient(to_bottom,#000,transparent_55%)]" />
            <!-- pedestal -->
            <div class="absolute bottom-0 h-1 w-28 rounded-full bg-gradient-to-r from-transparent via-titan-400/50 to-transparent"></div>
          </div>
          <p class="mt-7 font-display text-xl font-bold text-white">{a.milestone}</p>
          <p class="mt-1 text-sm font-semibold text-titan-400">{a.reward}</p>
          <p class="mt-2 text-[13px] leading-relaxed text-chrome-300/60">{a.note}</p>
        </div>
      ))}
    </div>

    <!-- 1MM cinematic stage -->
    <div class="reveal beam relative mt-6 overflow-hidden rounded-[28px] border border-gold-600/30 shadow-gold">
      <!-- stage background -->
      <div class="absolute inset-0 bg-gradient-to-b from-[#16100a] via-[#0c1626] to-[#070f1c]"></div>
      <div class="pointer-events-none absolute inset-0">
        <!-- top spotlight -->
        <div class="absolute left-1/2 top-[-10%] h-[420px] w-[520px] -translate-x-1/2 bg-[radial-gradient(circle_at_50%_0%,rgba(245,217,139,0.28),transparent_60%)]"></div>
        <!-- sparkles -->
        <span class="absolute left-[18%] top-[26%] h-1 w-1 rounded-full bg-gold-300 shadow-[0_0_10px_2px_rgba(245,217,139,0.8)] animate-floaty"></span>
        <span class="absolute right-[22%] top-[38%] h-1.5 w-1.5 rounded-full bg-gold-300/80 shadow-[0_0_10px_2px_rgba(245,217,139,0.7)] animate-floaty" style="animation-delay:1.1s"></span>
        <span class="absolute left-[42%] top-[16%] h-1 w-1 rounded-full bg-white shadow-[0_0_8px_2px_rgba(255,255,255,0.8)] animate-floaty" style="animation-delay:0.6s"></span>
      </div>

      <div class="relative grid items-center gap-10 p-8 sm:p-12 lg:grid-cols-[0.92fr_1.08fr]">
        <!-- plaque on a stage -->
        <div data-tilt-zone class="relative flex justify-center">
          <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle,rgba(231,190,106,0.28),transparent_62%)] blur-2xl"></div>
          <div data-tilt="9" class="tilt relative">
            <img src="/assets/placa-1mm.jpg" alt="Placa R$1.000.000 em vendas — Korvex" class="relative z-10 max-h-[22rem] w-auto rounded-xl object-contain drop-shadow-[0_40px_50px_rgba(0,0,0,0.75)]" loading="lazy" />
            <img src="/assets/placa-1mm.jpg" alt="" aria-hidden="true" class="absolute -bottom-10 left-1/2 max-h-[22rem] w-auto -translate-x-1/2 scale-y-[-1] rounded-xl object-contain opacity-25 blur-[2px] [mask-image:linear-gradient(to_bottom,#000,transparent_45%)]" />
          </div>
        </div>

        <div>
          <span class="inline-flex items-center gap-2 rounded-full border border-gold-600/40 bg-gold-600/10 px-3.5 py-1.5 text-[11px] font-bold uppercase tracking-[0.18em] text-gold-300">
            <span class="h-3.5 w-3.5" set:html={icon('trophy')}></span>
            O marco do milhão
          </span>
          <h3 class="h-display mt-5 text-4xl leading-tight sm:text-5xl">
            <span class="text-gold-gradient">R$1.000.000</span><br />em vendas.
          </h3>
          <p class="mt-4 max-w-lg text-pretty leading-relaxed text-chrome-200/85">
            A placa que poucos alcançam — e que muda o nível do jogo. E o reconhecimento não para na parede:
            junto com a placa de R$1 milhão, você concorre a <strong class="text-white">prêmios surpresa</strong>.
          </p>

          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            <div class="spotlight flex items-center gap-3 rounded-2xl border border-gold-600/25 bg-white/[0.03] p-4">
              <span class="flex h-10 w-10 flex-none items-center justify-center rounded-xl bg-gold-600/15 text-gold-300" set:html={icon('globe')}></span>
              <div>
                <p class="text-sm font-semibold text-white">Viagem internacional</p>
                <p class="text-[12px] text-chrome-300/60">Destinos de elite, all-in.</p>
              </div>
            </div>
            <div class="spotlight flex items-center gap-3 rounded-2xl border border-gold-600/25 bg-white/[0.03] p-4">
              <span class="flex h-10 w-10 flex-none items-center justify-center rounded-xl bg-gold-600/15 text-gold-300" set:html={icon('gift')}></span>
              <div>
                <p class="text-sm font-semibold text-white">Prêmios em dinheiro</p>
                <p class="text-[12px] text-chrome-300/60">E outras surpresas reservadas.</p>
              </div>
            </div>
          </div>

          <a href={REGISTER_URL} target="_blank" rel="noopener" class="btn btn-primary magnetic mt-7">
            Começar a construir meu marco
            <span class="h-4 w-4" set:html={icon('arrow')}></span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
