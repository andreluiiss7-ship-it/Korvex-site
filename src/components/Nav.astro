---
import { WHATSAPP_URL, REGISTER_URL } from '../lib/site';

const links = [
  { label: 'Checkout', href: '#checkout' },
  { label: 'Funil', href: '#funil' },
  { label: 'Membros', href: '#membros' },
  { label: 'Global', href: '#internacional' },
  { label: 'Taxas', href: '#pagamentos' },
  { label: 'Premiações', href: '#premiacoes' },
];
---

<header id="topo" class="fixed inset-x-0 top-0 z-50">
  <nav
    id="nav"
    class="mx-auto mt-3 flex w-[min(96%,1180px)] items-center justify-between rounded-full border border-suede-500/15 bg-ink/60 px-4 py-2.5 backdrop-blur-xl transition-all duration-300 sm:px-5"
  >
    <a href="#topo" class="flex items-center gap-2.5">
      <img src="/assets/logo-white.png" alt="Korvex" class="h-6 w-auto sm:h-7" />
    </a>

    <div class="hidden items-center gap-7 lg:flex">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="text-sm font-medium text-chrome-300/80 transition-colors hover:text-white"
          >
            {l.label}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-2">
      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noopener"
        class="hidden text-sm font-medium text-chrome-300/80 transition-colors hover:text-white sm:inline-flex"
      >
        Falar com o time
      </a>
      <a
        href={REGISTER_URL}
        target="_blank"
        rel="noopener"
        class="btn btn-primary !px-5 !py-2.5 text-[13px]"
      >
        Criar conta
      </a>
    </div>
  </nav>
</header>

<script>
  const nav = document.getElementById('nav');
  const onScroll = () => {
    if (!nav) return;
    if (window.scrollY > 24) {
      nav.classList.add('!bg-ink/85', 'shadow-depth');
    } else {
      nav.classList.remove('!bg-ink/85', 'shadow-depth');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
