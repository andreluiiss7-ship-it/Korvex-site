---
import { WHATSAPP_URL } from '../lib/site';

const cols = [
  {
    title: 'Plataforma',
    links: [
      { label: 'Funcionalidades', href: '#funcionalidades' },
      { label: 'Checkout', href: '#checkout' },
      { label: 'Recebimento', href: '#pagamentos' },
      { label: 'Área de membros', href: '#membros' },
    ],
  },
  {
    title: 'Korvex',
    links: [
      { label: 'Premiações', href: '#premiacoes' },
      { label: 'Korvex vs. comum', href: '#comparativo' },
      { label: 'Dúvidas frequentes', href: '#faq' },
      { label: 'Falar com o time', href: WHATSAPP_URL },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'Termos de uso', href: '/termos' },
      { label: 'Política de privacidade', href: '/privacidade' },
      { label: 'Política AML / KYC', href: '/aml-kyc' },
      { label: 'Canal de denúncias', href: WHATSAPP_URL },
    ],
  },
];
---

<footer class="relative mt-12 border-t border-suede-500/15 pt-16">
  <div class="section pb-12">
    <div class="grid gap-10 lg:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <img src="/assets/logo-white.png" alt="Korvex" class="h-7 w-auto" />
        <p class="mt-4 max-w-xs text-pretty text-sm leading-relaxed text-chrome-300/60">
          A infraestrutura de pagamentos para infoprodutores que levam a operação a sério.
          Receba no mesmo dia, venda no mundo todo, escale com padrão.
        </p>
        <a href={WHATSAPP_URL} target="_blank" rel="noopener" class="btn btn-ghost mt-6 !py-2.5 text-[13px]">
          Falar no WhatsApp
        </a>
      </div>

      {
        cols.map((c) => (
          <div>
            <p class="text-[12px] font-semibold uppercase tracking-wider text-chrome-300/60">{c.title}</p>
            <ul class="mt-4 space-y-2.5">
              {c.links.map((l) => (
                <li>
                  <a href={l.href} class="text-sm text-chrome-300/70 transition-colors hover:text-white">{l.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>

  <div class="border-t border-suede-500/10">
    <div class="section flex flex-col items-center justify-between gap-3 py-6 sm:flex-row">
      <p class="text-[12px] text-chrome-300/60">© 2026 Korvex Tecnologia. Todos os direitos reservados.</p>
      <p class="text-[12px] text-chrome-300/60">Feito para quem vende sério.</p>
    </div>
  </div>
</footer>
