---
const stats = [
  { big: 'R$ 25M+', label: 'vendidos online juntos' },
  { big: '100%', label: 'feita por operadores' },
];
---

<section id="fundadores" class="relative overflow-hidden py-16 sm:py-20">
  <!-- ambient atmosphere -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div data-parallax="0.08" class="ambient-drift absolute right-[-8%] top-1/3 h-[420px] w-[680px] rounded-full bg-titan-600/[0.12] blur-[140px]"></div>
    <div data-parallax="0.05" class="absolute left-[-4%] bottom-1/4 h-[300px] w-[480px] rounded-full bg-gold-600/[0.05] blur-[120px]"></div>
  </div>

  <div class="section">
    <!-- editorial split: copy left, photo right -->
    <div class="reveal grid items-stretch gap-10 overflow-hidden rounded-[28px] border border-suede-500/15 bg-gradient-to-br from-navy-800/40 via-ink/60 to-ink/80 shadow-depth lg:grid-cols-[1fr_1fr] lg:gap-0">
      <!-- LEFT: copy + stats + signature -->
      <div class="relative p-8 sm:p-10 lg:p-14">
        <span class="kicker">A origem</span>

        <h2 class="h-display mt-6 text-3xl leading-[1.04] sm:text-[2.6rem] lg:text-[3rem]">
          Construída por quem<br />
          já <span class="font-editorial italic font-normal text-titan-gradient">operou no jogo.</span>
        </h2>

        <p class="mt-6 max-w-xl text-pretty leading-relaxed text-chrome-300/80">
          André e Vinícius já venderam mais de <strong class="text-white">R$25 milhões</strong> na internet.
          A Korvex é o gateway que eles próprios queriam ter tido.
        </p>

        <!-- editorial signature -->
        <div class="sig-line mt-7 text-lg">
          André &amp; Vinícius <span class="text-chrome-300/50 not-italic font-sans text-[11px] uppercase tracking-[0.18em] ml-2">Fundadores</span>
        </div>

        <!-- stats with mono labels -->
        <dl class="mt-9 grid grid-cols-2 gap-x-6 gap-y-2 border-t border-suede-500/15 pt-7 sm:gap-x-12">
          {stats.map((s) => (
            <div>
              <dt class="font-editorial text-4xl italic leading-none text-titan-gradient sm:text-5xl">{s.big}</dt>
              <dd class="mt-3 font-mono text-[11px] uppercase tracking-[0.14em] text-chrome-300/55">{s.label}</dd>
            </div>
          ))}
        </dl>
      </div>

      <!-- RIGHT: editorial portrait with refined framing -->
      <div class="relative min-h-[480px] overflow-hidden lg:min-h-0">
        <!-- main image -->
        <div
          class="absolute inset-0 bg-cover transition-transform duration-700"
          style="background-image: url('/assets/founders.jpg'); background-position: center 25%;"
          data-tilt-zone
        ></div>

        <!-- left-edge fade into the card so the photo flows from the copy panel -->
        <div class="pointer-events-none absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-ink/95 via-ink/40 to-transparent lg:from-ink/85"></div>
        <!-- bottom gradient — só ali, fora dos rostos -->
        <div class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-ink/85 via-ink/30 to-transparent"></div>
        <!-- subtle blue tint overlay -->
        <div class="pointer-events-none absolute inset-0 bg-gradient-to-tr from-titan-600/10 via-transparent to-transparent"></div>

        <!-- "year" tag, top-right -->
        <div class="absolute right-5 top-5 z-10">
          <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-black/45 px-3 py-1.5 text-[10px] font-mono uppercase tracking-[0.16em] text-chrome-200 backdrop-blur">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 shadow-[0_0_8px_2px_rgba(52,211,153,0.55)]"></span>
            Foto · 2026
          </span>
        </div>

        <!-- caption bottom-left, fora dos rostos -->
        <div class="absolute inset-x-6 bottom-6 z-10 flex items-end justify-between gap-3">
          <div>
            <p class="font-display text-[15px] font-semibold leading-tight text-white">André &amp; Vinícius</p>
            <p class="mt-0.5 font-mono text-[10px] uppercase tracking-[0.18em] text-chrome-200/75">Fundadores · Korvex</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
