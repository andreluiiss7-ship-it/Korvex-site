---
import { icon } from '../lib/icons';
import { REGISTER_URL } from '../lib/site';

// moedas em órbita (símbolo + código)
const ringA = [
  { s: '$', c: 'USD' },
  { s: '€', c: 'EUR' },
  { s: '£', c: 'GBP' },
  { s: 'R$', c: 'BRL' },
];
const ringB = [
  { s: '¥', c: 'JPY' },
  { s: 'A$', c: 'AUD' },
  { s: 'C$', c: 'CAD' },
  { s: '₣', c: 'CHF' },
];

// liquidação cross-border
const settle = [
  { flag: '🇺🇸', cur: 'USD', amount: '12.480,00', up: true },
  { flag: '🇪🇺', cur: 'EUR', amount: '9.215,40', up: true },
  { flag: '🇬🇧', cur: 'GBP', amount: '4.060,00', up: false },
  { flag: '🇧🇷', cur: 'BRL', amount: '128.940,00', up: true },
];
---

<section id="internacional" class="relative overflow-hidden py-28 sm:py-36">
  <!-- ambient: aurora + grid + vignette -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute inset-0 vignette bg-grid-faint [background-size:60px_60px] opacity-40"></div>
    <div class="absolute left-1/2 top-1/2 h-[760px] w-[760px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[conic-gradient(from_120deg,rgba(43,95,160,0.22),rgba(111,163,224,0.06),rgba(201,146,58,0.08),rgba(43,95,160,0.22))] blur-[120px] opacity-70"></div>
  </div>

  <div class="section">
    <!-- header — centered cinematic (mantém pq é o climax do produto) -->
    <div class="reveal mx-auto max-w-3xl text-center">
      <span class="kicker justify-center">Cross-border</span>
      <h2 class="h-display mt-6 text-4xl leading-[1.02] sm:text-[3.4rem]">
        Seu produto não tem fronteira.<br />
        Seu recebimento <span class="font-editorial italic font-normal text-titan-gradient">também não.</span>
      </h2>
      <p class="mx-auto mt-6 max-w-xl text-pretty text-lg leading-relaxed text-chrome-300/75">
        Cobre o cliente na moeda dele, liquide na sua. A Korvex processa em
        <strong class="text-white"> 135+ moedas</strong>, com checkout no idioma de quem compra.
      </p>
    </div>

    <!-- stage: globe + orbits + arcs + FX cards -->
    <div data-tilt-zone class="relative mx-auto mt-16 grid max-w-6xl items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
      <!-- LEFT: the globe stage -->
      <div class="relative mx-auto aspect-square w-full max-w-[480px]">
        <!-- orbit ring A -->
        <div class="absolute inset-[5%] rounded-full border border-suede-500/15"></div>
        <div class="absolute inset-[5%] animate-spin-slow">
          {ringA.map((m, i) => (
            <div class="absolute inset-0" style={`transform: rotate(${i * 90}deg)`}>
              <div class="absolute left-1/2 top-0 -translate-x-1/2 -translate-y-1/2" style={`transform: translate(-50%,-50%) rotate(${-i * 90}deg)`}>
                <div class="animate-spin-rev">
                  <div class="flex h-12 w-12 items-center justify-center rounded-2xl border border-suede-500/25 bg-ink/85 font-display text-sm font-bold text-chrome-100 shadow-glow backdrop-blur">
                    {m.s}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- orbit ring B (smaller, reverse) -->
        <div class="absolute inset-[19%] rounded-full border border-suede-500/10"></div>
        <div class="absolute inset-[19%] animate-spin-rev">
          {ringB.map((m, i) => (
            <div class="absolute inset-0" style={`transform: rotate(${i * 90 + 45}deg)`}>
              <div class="absolute left-1/2 top-0" style={`transform: translate(-50%,-50%) rotate(${-i * 90 - 45}deg)`}>
                <div class="animate-spin-slow">
                  <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-suede-500/20 bg-ink/80 text-[11px] font-bold text-suede-300 backdrop-blur">
                    {m.s}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- GLOBE — foto real da Terra à noite (NASA-style) com tratamento navy -->
        <div data-tilt="8" class="tilt absolute inset-[28%]">
          <div class="relative h-full w-full overflow-hidden rounded-full border border-titan-500/25 shadow-[0_30px_90px_-20px_rgba(43,95,160,0.7),inset_0_0_60px_rgba(0,0,0,0.55)]">
            <!-- Foto real da Terra como base -->
            <img src="/assets/earth-night.jpg" alt="" aria-hidden="true" class="absolute inset-0 h-full w-full scale-[1.4] object-cover" style="object-position: 50% 35%; filter: saturate(0.85) brightness(0.95);" loading="lazy" decoding="async" />
            <!-- Tint navy/suede para harmonizar com a paleta -->
            <div class="absolute inset-0 mix-blend-color" style="background: linear-gradient(135deg, rgba(43,95,160,0.55), rgba(13,34,56,0.4));"></div>
            <!-- Vinheta nas bordas para acentuar a esfera -->
            <div class="absolute inset-0" style="background: radial-gradient(circle at 30% 25%, transparent 40%, rgba(7,16,29,0.55) 90%);"></div>
            <!-- Brilho atmosférico no topo -->
            <div class="absolute inset-0" style="background: radial-gradient(80% 60% at 28% 18%, rgba(111,163,224,0.18), transparent 50%);"></div>
            <!-- Meridianos / paralelos sobrepostos -->
            <svg viewBox="0 0 200 200" class="absolute inset-0 h-full w-full text-titan-400/30">
              <g fill="none" stroke="currentColor" stroke-width="0.5">
                <circle cx="100" cy="100" r="99" />
                <ellipse cx="100" cy="100" rx="99" ry="34" />
                <ellipse cx="100" cy="100" rx="99" ry="66" />
                <ellipse cx="100" cy="100" rx="34" ry="99" />
                <ellipse cx="100" cy="100" rx="66" ry="99" />
              </g>
            </svg>
            <!-- Pings de localização -->
            <span class="absolute left-[34%] top-[38%] h-2 w-2 rounded-full bg-titan-400 shadow-[0_0_10px_2px_rgba(111,163,224,0.9)]"></span>
            <span class="absolute left-[34%] top-[38%] h-2 w-2 rounded-full border border-titan-400/60" style="animation:pulse-ring 2.6s ease-out infinite"></span>
            <span class="absolute left-[62%] top-[30%] h-2 w-2 rounded-full bg-gold-300 shadow-[0_0_10px_2px_rgba(245,217,139,0.8)]"></span>
            <span class="absolute left-[62%] top-[30%] h-2 w-2 rounded-full border border-gold-300/60" style="animation:pulse-ring 2.6s ease-out infinite 0.8s"></span>
            <span class="absolute left-[55%] top-[64%] h-1.5 w-1.5 rounded-full bg-chrome-200 shadow-[0_0_8px_2px_rgba(220,229,238,0.7)]"></span>
          </div>
        </div>

        <!-- connection arcs over everything -->
        <svg viewBox="0 0 480 480" class="pointer-events-none absolute inset-0 h-full w-full">
          <defs>
            <linearGradient id="arc" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#6fa3e0" stop-opacity="0" />
              <stop offset="0.5" stop-color="#6fa3e0" stop-opacity="0.9" />
              <stop offset="1" stop-color="#f5d98b" stop-opacity="0" />
            </linearGradient>
          </defs>
          <path d="M150 210 Q 240 90 320 175" fill="none" stroke="url(#arc)" stroke-width="1.5" stroke-dasharray="6 8" style="animation:dash-travel 6s linear infinite" />
          <path d="M320 175 Q 360 300 250 330" fill="none" stroke="url(#arc)" stroke-width="1.5" stroke-dasharray="6 8" style="animation:dash-travel 7s linear infinite" />
          <path d="M150 210 Q 130 330 250 330" fill="none" stroke="url(#arc)" stroke-width="1.2" stroke-dasharray="5 9" style="animation:dash-travel 8s linear infinite" />
        </svg>

        <!-- floating FX cards -->
        <div class="absolute -left-4 top-[12%] animate-floaty">
          <div class="flex items-center gap-2.5 rounded-xl border border-suede-500/25 bg-ink/85 px-3 py-2 shadow-glow backdrop-blur">
            <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-emerald-500/15 text-emerald-400 text-xs font-bold">$</span>
            <div>
              <p class="text-[11px] font-semibold text-white">USD 1.200,00</p>
              <p class="text-[9px] text-emerald-400">venda aprovada</p>
            </div>
          </div>
        </div>
        <div class="absolute -right-2 top-[40%] animate-floaty" style="animation-delay:1.2s">
          <div class="flex items-center gap-2.5 rounded-xl border border-suede-500/25 bg-ink/85 px-3 py-2 shadow-glow backdrop-blur">
            <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-titan-600/20 text-titan-400 text-xs font-bold">€</span>
            <div>
              <p class="text-[11px] font-semibold text-white">EUR 980,00</p>
              <p class="text-[9px] text-titan-400">checkout em alemão</p>
            </div>
          </div>
        </div>
        <div class="absolute bottom-[10%] left-[14%] animate-floaty" style="animation-delay:0.6s">
          <div class="flex items-center gap-2.5 rounded-xl border border-gold-600/25 bg-ink/85 px-3 py-2 shadow-gold backdrop-blur">
            <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-gold-600/15 text-gold-300 text-xs font-bold">R$</span>
            <div>
              <p class="text-[11px] font-semibold text-white">BRL 6.420,00</p>
              <p class="text-[9px] text-gold-300">liquidado D0</p>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: cross-border settlement panel + stats -->
      <div class="reveal">
        <div class="beam card spotlight overflow-hidden rounded-3xl p-6 sm:p-7">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="h-8 w-8 rounded-lg bg-titan-600/15 p-2 text-titan-400" set:html={icon('globe')}></span>
              <p class="font-display text-sm font-semibold text-white">Liquidação cross-border</p>
            </div>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-500/10 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-emerald-400 font-mono">
              <span class="relative inline-flex h-1.5 w-1.5">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
              </span>
              ao vivo
            </span>
          </div>

          <div class="mt-5 divide-y divide-suede-500/10">
            {settle.map((s, i) => (
              <div class="flex items-center justify-between py-3">
                <div class="flex items-center gap-3">
                  <span class="relative inline-flex">
                    <span class="text-lg leading-none">{s.flag}</span>
                    <span class="absolute -inset-1 rounded-full" style={`animation: pulse-station 2.4s ease-in-out infinite; animation-delay:${i * 0.4}s; --pulse-c: rgba(111,160,255,0.6);`}></span>
                  </span>
                  <span class="font-display text-sm font-semibold text-white">{s.cur}</span>
                </div>
                <div class="flex items-center gap-3">
                  <span class="font-mono text-sm text-chrome-100" style="font-feature-settings: 'tnum';">{s.amount}</span>
                  <span class={`flex h-5 w-5 items-center justify-center rounded ${s.up ? 'text-emerald-400' : 'text-suede-300'}`}>
                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d={s.up ? 'M6 14l6-6 6 6' : 'M6 10l6 6 6-6'} stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-5 flex items-center justify-between rounded-xl border border-suede-500/15 bg-white/[0.025] px-4 py-3" style="background: linear-gradient(180deg, rgba(59,130,246,0.06), transparent);">
            <span class="text-[12px] text-chrome-300/60">Total convertido para BRL</span>
            <span class="font-display text-lg font-bold text-titan-gradient" data-counter data-target="152617.80" data-prefix="R$ " data-decimals="2">R$ 152.617,80</span>
          </div>
        </div>

        <a href={REGISTER_URL} target="_blank" rel="noopener" class="btn btn-primary magnetic mt-5">
          Quero vender no mundo todo
          <span class="h-4 w-4" set:html={icon('arrow')}></span>
        </a>
      </div>
    </div>
  </div>
</section>
