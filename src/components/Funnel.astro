---
import { icon } from '../lib/icons';
import { REGISTER_URL } from '../lib/site';

const features = [
  { icon: 'cursor',  title: 'Arraste e solte', desc: 'Construa o fluxo sem código nenhum.' },
  { icon: 'layers',  title: 'Upsell · Downsell · Order Bump', desc: 'Suba o ticket sem nova compra do cliente.' },
  { icon: 'sparkle', title: 'Conversão em tempo real',     desc: 'Veja % de aceite de cada nó na hora.' },
];
---

<section id="funil" class="relative py-16 sm:py-20">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div data-parallax="0.08" class="ambient-drift absolute right-[5%] top-1/3 h-[420px] w-[680px] rounded-full bg-titan-600/10 blur-[140px]"></div>
    <div data-parallax="0.05" class="absolute left-[5%] top-1/2 h-[280px] w-[480px] rounded-full bg-gold-600/[0.05] blur-[140px]"></div>
  </div>

  <div class="section">
    <!-- header — split: title left, copy right -->
    <div class="reveal grid items-end gap-8 lg:grid-cols-[1.15fr_0.85fr]">
      <div>
        <span class="chapter">03 · Funil</span>
        <h2 class="h-display mt-6 text-4xl leading-[1.0] sm:text-[3.2rem]">
          O ticket médio sobe<br />
          a cada bloco<br />
          que você <span class="font-display font-black">solta.</span>
        </h2>
      </div>
      <p class="max-w-md text-pretty text-lg leading-relaxed text-chrome-300/72">
        Construtor visual de verdade. Arraste, conecte e veja a conversão de cada nó em tempo real.
        <strong class="text-white">Você desenha a jornada — a Korvex executa.</strong>
      </p>
    </div>

    <!-- HERO IMAGE: real funnel builder screenshot, framed editorially -->
    <div class="reveal mt-12">
      <div data-tilt-zone class="relative mx-auto max-w-6xl">
        <!-- glow underlay -->
        <div class="pointer-events-none absolute -inset-6 -z-10 rounded-[36px] bg-gradient-to-tr from-titan-600/30 via-transparent to-gold-600/10 blur-3xl"></div>

        <div data-tilt="4" class="tilt browser relative overflow-hidden rounded-2xl border border-suede-500/25 shadow-depth">
          <div class="browser-bar">
            <span class="dot bg-[#ff5f57]/80"></span>
            <span class="dot bg-[#febc2e]/80"></span>
            <span class="dot bg-[#28c840]/80"></span>
            <span class="ml-3 rounded-md bg-white/5 px-2.5 py-1 text-[11px] text-chrome-300/70">app.korvex.com.br/funil-de-vendas</span>
            <span class="ml-auto hidden items-center gap-1.5 text-[10px] text-emerald-400 sm:flex">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
              Auto-save
            </span>
          </div>

          <!-- real product screenshot -->
          <div class="relative">
            <img
              src="/assets/funnel-builder.jpg"
              alt="Construtor de funil Korvex — arrastar e soltar"
              class="block w-full"
              loading="lazy"
            />
            <!-- subtle dark overlay so floating chips read better -->
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink/30 via-transparent to-transparent"></div>
          </div>
        </div>

        <!-- floating accent: "Upsell aceito" — mobile: top-right inside; lg: top-right outside -->
        <div class="absolute z-20 flex top-2 right-2 lg:top-[-22px] lg:right-[-32px]">
          <div class="flex items-center gap-2.5 rounded-2xl border border-titan-500/40 bg-ink/95 px-3.5 py-2.5 shadow-glow backdrop-blur-xl">
            <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-titan-600/20 text-titan-300" set:html={icon('bolt')}></span>
            <div>
              <p class="font-display text-[12px] font-bold leading-none text-white">+ R$ 497</p>
              <p class="mt-0.5 text-[10px] text-titan-300">Upsell 1-clique aceito</p>
            </div>
          </div>
        </div>

        <!-- floating accent: "Conversão" — mobile: bottom-left inside; lg: bottom-left outside -->
        <div class="absolute z-20 flex -bottom-3 left-2 lg:bottom-[-22px] lg:left-[-32px]">
          <div class="flex items-center gap-2.5 rounded-2xl border border-emerald-500/40 bg-ink/95 px-3.5 py-2.5 shadow-glow backdrop-blur-xl">
            <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-500/15 text-emerald-400">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 17l6-6 4 4 8-8" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 7h7v7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <div>
              <p class="font-display text-[12px] font-bold leading-none text-white">+62% ticket médio</p>
              <p class="mt-0.5 text-[10px] text-emerald-400">vs. checkout único</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- bottom row: 3 features (editorial list) + stats + CTA -->
    <div class="mt-12 grid items-start gap-8 lg:grid-cols-[1fr_1.1fr]">
      <!-- features — numbered editorial list, no cards -->
      <div class="reveal divide-y divide-suede-500/12">
        {features.map((f, i) => (
          <div class="flex items-start gap-5 py-5 first:pt-0" style={`transition-delay:${i * 60}ms`}>
            <span class="font-editorial text-3xl italic leading-none text-titan-400/80">0{i + 1}</span>
            <div>
              <p class="font-display text-[15px] font-bold text-white">{f.title}</p>
              <p class="mt-1 text-[13px] leading-relaxed text-chrome-300/65">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- stat band + CTA -->
      <div class="reveal">
        <div class="rounded-3xl border border-suede-500/20 bg-gradient-to-br from-navy-800/60 to-ink/70 p-7 sm:p-8">
          <p class="text-[11px] uppercase tracking-wider text-chrome-300/60">Resultado típico do funil completo</p>
          <div class="mt-5 grid grid-cols-3 gap-4">
            <div>
              <p class="font-editorial text-3xl leading-none text-white sm:text-4xl">R$ 2.4k</p>
              <p class="mt-2 text-[11px] uppercase tracking-wider text-chrome-300/60">Ticket médio</p>
            </div>
            <div class="border-l border-suede-500/15 pl-4">
              <p class="font-editorial text-3xl leading-none text-titan-400 sm:text-4xl">+62%</p>
              <p class="mt-2 text-[11px] uppercase tracking-wider text-chrome-300/60">Receita / venda</p>
            </div>
            <div class="border-l border-suede-500/15 pl-4">
              <p class="font-editorial text-3xl leading-none text-white sm:text-4xl">3 min</p>
              <p class="mt-2 text-[11px] uppercase tracking-wider text-chrome-300/60">Pra montar</p>
            </div>
          </div>

          <div class="mt-6 flex flex-wrap items-center gap-2.5 border-t border-suede-500/15 pt-5">
            {['Checkout', 'Order Bump', 'Upsell', 'Downsell', 'Membros', 'Página'].map((b, i) => (
              <span class={`inline-flex items-center gap-1.5 rounded-md border px-2.5 py-1 text-[10px] font-medium ${i === 0 ? 'border-titan-500/50 bg-titan-600/15 text-white' : 'border-suede-500/20 bg-white/[0.02] text-chrome-300/70'}`}>
                <span class="h-1 w-1 rounded-full bg-titan-400"></span>
                {b}
              </span>
            ))}
          </div>

          <a href={REGISTER_URL} target="_blank" rel="noopener" class="btn btn-primary magnetic mt-6">
            Quero montar meu funil
            <span class="h-4 w-4" set:html={icon('arrow')}></span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
