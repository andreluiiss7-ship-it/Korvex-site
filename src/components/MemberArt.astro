---
interface Props {
  kind: 'fundamentos' | 'oferta' | 'trafego' | 'funil';
  class?: string;
}
const { kind, class: cls = '' } = Astro.props;
const uid = `art-${Math.random().toString(36).slice(2, 9)}`;
---

{kind === 'fundamentos' && (
  <svg viewBox="0 0 400 225" preserveAspectRatio="xMidYMid slice" class={`absolute inset-0 h-full w-full ${cls}`} aria-hidden="true">
    <defs>
      <linearGradient id={`bg-${uid}`} x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#0b2d52"/>
        <stop offset="60%" stop-color="#071e38"/>
        <stop offset="100%" stop-color="#040e1c"/>
      </linearGradient>
      <linearGradient id={`face1-${uid}`} x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#1e5080"/>
        <stop offset="100%" stop-color="#0a1d33"/>
      </linearGradient>
      <linearGradient id={`face2-${uid}`} x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#0d2a48"/>
        <stop offset="100%" stop-color="#060f1e"/>
      </linearGradient>
      <radialGradient id={`glow-${uid}`} cx="40%" cy="30%" r="55%">
        <stop offset="0%" stop-color="#3e78c0" stop-opacity="0.4"/>
        <stop offset="100%" stop-color="#3e78c0" stop-opacity="0"/>
      </radialGradient>
      <radialGradient id={`topglow-${uid}`} cx="50%" cy="0%" r="50%">
        <stop offset="0%" stop-color="#f5d98b" stop-opacity="0.25"/>
        <stop offset="100%" stop-color="#f5d98b" stop-opacity="0"/>
      </radialGradient>
      <filter id={`blur-${uid}`}>
        <feGaussianBlur stdDeviation="4"/>
      </filter>
    </defs>
    <rect width="400" height="225" fill={`url(#bg-${uid})`}/>
    <rect width="400" height="225" fill={`url(#glow-${uid})`}/>
    <!-- Blueprint grid perspective -->
    <g opacity="0.35" fill="none" stroke="#7ea8d8" stroke-width="0.5">
      <!-- horizontal convergence lines -->
      <line x1="0" y1="170" x2="400" y2="155"/>
      <line x1="0" y1="185" x2="400" y2="172"/>
      <line x1="0" y1="155" x2="400" y2="138"/>
      <!-- vertical convergence lines -->
      <line x1="60" y1="100" x2="80" y2="225"/>
      <line x1="130" y1="90" x2="160" y2="225"/>
      <line x1="200" y1="85" x2="240" y2="225"/>
      <line x1="270" y1="90" x2="320" y2="225"/>
      <line x1="340" y1="100" x2="400" y2="225"/>
    </g>
    <!-- Soft ambient glow blur layer -->
    <ellipse cx="160" cy="110" rx="100" ry="60" fill="#3e78c0" opacity="0.12" filter={`url(#blur-${uid})`}/>
    <!-- Ground reflection -->
    <ellipse cx="200" cy="195" rx="80" ry="8" fill="#3e78c0" opacity="0.2"/>
    <!-- BASE BLOCK (largest) -->
    <g>
      <!-- top face -->
      <polygon points="120,155 200,135 280,155 200,175" fill="#1a3d60" stroke="#6fa3e0" stroke-width="0.8" stroke-opacity="0.7"/>
      <!-- left face -->
      <polygon points="120,155 120,185 200,205 200,175" fill={`url(#face1-${uid})`} stroke="#4a80b0" stroke-width="0.6" stroke-opacity="0.5"/>
      <!-- right face -->
      <polygon points="280,155 280,185 200,205 200,175" fill={`url(#face2-${uid})`} stroke="#3a6090" stroke-width="0.6" stroke-opacity="0.4"/>
      <!-- subtle grid on top face -->
      <line x1="160" y1="155" x2="160" y2="175" stroke="#7ea8d8" stroke-width="0.4" stroke-opacity="0.5"/>
      <line x1="200" y1="145" x2="240" y2="165" stroke="#7ea8d8" stroke-width="0.4" stroke-opacity="0.5"/>
    </g>
    <!-- MID BLOCK -->
    <g>
      <polygon points="140,118 200,100 260,118 200,136" fill="#245a8c" stroke="#6fa3e0" stroke-width="0.8" stroke-opacity="0.75"/>
      <polygon points="140,118 140,143 200,161 200,136" fill="#122e4e" stroke="#5a80a8" stroke-width="0.6" stroke-opacity="0.5"/>
      <polygon points="260,118 260,143 200,161 200,136" fill="#0d2038" stroke="#4a6888" stroke-width="0.6" stroke-opacity="0.4"/>
      <!-- Detail lines on mid -->
      <line x1="170" y1="127" x2="200" y2="118" stroke="#a0c4e8" stroke-width="0.5" stroke-opacity="0.6"/>
      <line x1="230" y1="127" x2="200" y2="118" stroke="#a0c4e8" stroke-width="0.5" stroke-opacity="0.4"/>
    </g>
    <!-- SMALL BLOCK (top) -->
    <g>
      <polygon points="160,85 200,68 240,85 200,102" fill="#2e6fa8" stroke="#90c0e8" stroke-width="0.9" stroke-opacity="0.85"/>
      <polygon points="160,85 160,106 200,123 200,102" fill="#163a5e" stroke="#5a8aaa" stroke-width="0.6" stroke-opacity="0.5"/>
      <polygon points="240,85 240,106 200,123 200,102" fill="#102a48" stroke="#486a88" stroke-width="0.6" stroke-opacity="0.4"/>
    </g>
    <!-- APEX CRYSTAL (very top) -->
    <g>
      <polygon points="175,60 200,42 225,60 200,78" fill="#3a7ec0" stroke="#b0d8f8" stroke-width="0.9" stroke-opacity="0.9"/>
      <polygon points="175,60 175,74 200,88 200,78" fill="#1a4a78"/>
      <polygon points="225,60 225,74 200,88 200,78" fill="#122e58"/>
      <!-- Gold crown top -->
      <ellipse cx="200" cy="42" rx="6" ry="3" fill="#f5d98b" opacity="0.9"/>
      <line x1="200" y1="39" x2="200" y2="32" stroke="#f5d98b" stroke-width="1.2" stroke-opacity="0.8"/>
      <rect width="400" height="225" fill={`url(#topglow-${uid})`}/>
    </g>
    <!-- Floating data dots -->
    <g fill="#a0c4e8" opacity="0.7">
      <circle cx="60" cy="55" r="1.5"/><circle cx="85" cy="42" r="1"/><circle cx="45" cy="75" r="1.2"/>
      <circle cx="340" cy="48" r="1.5"/><circle cx="360" cy="65" r="1"/><circle cx="320" cy="70" r="1.2"/>
      <circle cx="100" cy="110" r="1"/><circle cx="300" cy="105" r="1.2"/>
    </g>
    <!-- Connection lines (blueprint) -->
    <g stroke="#6fa3e0" stroke-width="0.5" stroke-opacity="0.4" fill="none" stroke-dasharray="3 5">
      <line x1="60" y1="55" x2="130" y2="130"/>
      <line x1="340" y1="48" x2="270" y2="128"/>
    </g>
    <!-- Label chip -->
    <rect x="14" y="14" width="82" height="16" rx="4" fill="#0a1a2f" fill-opacity="0.85" stroke="#3e78c0" stroke-width="0.7" stroke-opacity="0.6"/>
    <circle cx="24" cy="22" r="2.5" fill="#6fa3e0"/>
    <rect x="31" y="19" width="56" height="6" rx="1.5" fill="#a0c4e8" fill-opacity="0.6"/>
  </svg>
)}

{kind === 'oferta' && (
  <svg viewBox="0 0 400 225" preserveAspectRatio="xMidYMid slice" class={`absolute inset-0 h-full w-full ${cls}`} aria-hidden="true">
    <defs>
      <linearGradient id={`bg-${uid}`} x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#122840"/>
        <stop offset="55%" stop-color="#0c1e32"/>
        <stop offset="100%" stop-color="#060e1a"/>
      </linearGradient>
      <radialGradient id={`targetglow-${uid}`} cx="50%" cy="52%" r="45%">
        <stop offset="0%" stop-color="#f5d98b" stop-opacity="0.22"/>
        <stop offset="60%" stop-color="#e7be6a" stop-opacity="0.06"/>
        <stop offset="100%" stop-color="#c9923a" stop-opacity="0"/>
      </radialGradient>
      <radialGradient id={`innerglow-${uid}`} cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#f5d98b" stop-opacity="0.5"/>
        <stop offset="100%" stop-color="#f5d98b" stop-opacity="0"/>
      </radialGradient>
      <filter id={`softblur-${uid}`}><feGaussianBlur stdDeviation="3"/></filter>
    </defs>
    <rect width="400" height="225" fill={`url(#bg-${uid})`}/>
    <rect width="400" height="225" fill={`url(#targetglow-${uid})`}/>
    <!-- Outer atmosphere rings -->
    <g fill="none" stroke="#7ea8d8" stroke-opacity="0.12">
      <circle cx="200" cy="118" r="105" stroke-width="16"/>
    </g>
    <!-- Target rings -->
    <circle cx="200" cy="118" r="90" fill="none" stroke="#3e78c0" stroke-width="0.6" stroke-opacity="0.35"/>
    <circle cx="200" cy="118" r="72" fill="none" stroke="#6fa3e0" stroke-width="0.7" stroke-opacity="0.45"/>
    <circle cx="200" cy="118" r="52" fill="none" stroke="#8fb8e0" stroke-width="0.8" stroke-opacity="0.55"/>
    <circle cx="200" cy="118" r="34" fill="none" stroke="#b0d0f0" stroke-width="0.9" stroke-opacity="0.65"/>
    <circle cx="200" cy="118" r="18" fill="none" stroke="#d8ecff" stroke-width="1" stroke-opacity="0.75"/>
    <circle cx="200" cy="118" r="7" fill="#f5d98b" opacity="0.9"/>
    <circle cx="200" cy="118" r="7" fill={`url(#innerglow-${uid})`} filter={`url(#softblur-${uid})`}/>
    <!-- Cross hairs -->
    <g stroke="#6fa3e0" stroke-width="0.5" stroke-opacity="0.4">
      <line x1="200" y1="25" x2="200" y2="210"/>
      <line x1="105" y1="118" x2="295" y2="118"/>
    </g>
    <!-- Trajectory arrows converging on target -->
    <g fill="none" stroke-linecap="round">
      <!-- From top-left -->
      <path d="M45 35 Q 110 60 185 112" stroke="#6fa3e0" stroke-width="1.4" stroke-opacity="0.8" stroke-dasharray="4 5"/>
      <path d="M182 105 L185 112 L192 108" stroke="#6fa3e0" stroke-width="1.4" stroke-opacity="0.8"/>
      <!-- From top-right -->
      <path d="M355 28 Q 295 58 218 110" stroke="#a0c4e8" stroke-width="1.2" stroke-opacity="0.7" stroke-dasharray="4 5"/>
      <path d="M215 104 L218 110 L212 106" stroke="#a0c4e8" stroke-width="1.2" stroke-opacity="0.7"/>
      <!-- From bottom-left -->
      <path d="M30 195 Q 100 170 183 124" stroke="#6fa3e0" stroke-width="1" stroke-opacity="0.55" stroke-dasharray="3 5"/>
      <!-- From right -->
      <path d="M380 118 Q 310 118 222 118" stroke="#a0c4e8" stroke-width="1" stroke-opacity="0.5" stroke-dasharray="3 5"/>
    </g>
    <!-- Message bubbles at trajectory origins -->
    <!-- Bubble 1 top-left -->
    <g>
      <rect x="18" y="20" width="62" height="22" rx="5" fill="#0c1e32" stroke="#6fa3e0" stroke-width="0.8" stroke-opacity="0.7"/>
      <circle cx="29" cy="31" r="4.5" fill="#1e4e7a"/>
      <rect x="38" y="26" width="34" height="4" rx="2" fill="#a0c4e8" fill-opacity="0.65"/>
      <rect x="38" y="33" width="22" height="3" rx="1.5" fill="#a0c4e8" fill-opacity="0.4"/>
    </g>
    <!-- Bubble 2 top-right -->
    <g>
      <rect x="316" y="15" width="68" height="22" rx="5" fill="#0c1e32" stroke="#b0d0f0" stroke-width="0.8" stroke-opacity="0.6"/>
      <rect x="324" y="22" width="52" height="4" rx="2" fill="#b0d0f0" fill-opacity="0.65"/>
      <rect x="324" y="29" width="34" height="3" rx="1.5" fill="#b0d0f0" fill-opacity="0.4"/>
    </g>
    <!-- Bubble 3 bottom-left (offer) -->
    <g>
      <rect x="18" y="180" width="68" height="30" rx="5" fill="#0c1e32" stroke="#f5d98b" stroke-width="0.8" stroke-opacity="0.5"/>
      <rect x="26" y="188" width="50" height="4" rx="2" fill="#f5d98b" fill-opacity="0.7"/>
      <rect x="26" y="196" width="34" height="3" rx="1.5" fill="#f5d98b" fill-opacity="0.4"/>
      <rect x="26" y="202" width="24" height="3" rx="1.5" fill="#e7be6a" fill-opacity="0.3"/>
    </g>
    <!-- Impact spark particles -->
    <g fill="#f5d98b" opacity="0.85">
      <circle cx="192" cy="108" r="1.2"/>
      <circle cx="208" cy="128" r="1"/>
      <circle cx="214" cy="110" r="1.4"/>
      <circle cx="186" cy="126" r="0.9"/>
    </g>
    <!-- Label chip -->
    <rect x="14" y="14" width="82" height="16" rx="4" fill="#0a1a2f" fill-opacity="0.85" stroke="#e7be6a" stroke-width="0.7" stroke-opacity="0.5"/>
    <circle cx="24" cy="22" r="2.5" fill="#f5d98b"/>
    <rect x="31" y="19" width="56" height="6" rx="1.5" fill="#f5d98b" fill-opacity="0.55"/>
  </svg>
)}

{kind === 'trafego' && (
  <svg viewBox="0 0 400 225" preserveAspectRatio="xMidYMid slice" class={`absolute inset-0 h-full w-full ${cls}`} aria-hidden="true">
    <defs>
      <linearGradient id={`bg-${uid}`} x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#0e2d4e"/>
        <stop offset="55%" stop-color="#09203a"/>
        <stop offset="100%" stop-color="#04101e"/>
      </linearGradient>
      <radialGradient id={`earthglow-${uid}`} cx="50%" cy="85%" r="60%">
        <stop offset="0%" stop-color="#3e78c0" stop-opacity="0.45"/>
        <stop offset="100%" stop-color="#3e78c0" stop-opacity="0"/>
      </radialGradient>
      <linearGradient id={`arc1-${uid}`} x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#6fa3e0" stop-opacity="0"/>
        <stop offset="50%" stop-color="#f5d98b" stop-opacity="1"/>
        <stop offset="100%" stop-color="#6fa3e0" stop-opacity="0"/>
      </linearGradient>
      <linearGradient id={`arc2-${uid}`} x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#a0c4e8" stop-opacity="0"/>
        <stop offset="50%" stop-color="#a0c4e8" stop-opacity="0.9"/>
        <stop offset="100%" stop-color="#a0c4e8" stop-opacity="0"/>
      </linearGradient>
      <clipPath id={`clipcirc-${uid}`}>
        <rect x="0" y="0" width="400" height="225"/>
      </clipPath>
    </defs>
    <rect width="400" height="225" fill={`url(#bg-${uid})`}/>
    <!-- Stars -->
    <g fill="white">
      <circle cx="50" cy="25" r="0.9" opacity="0.7"/>
      <circle cx="120" cy="15" r="0.7" opacity="0.5"/>
      <circle cx="200" cy="10" r="1" opacity="0.6"/>
      <circle cx="280" cy="20" r="0.8" opacity="0.5"/>
      <circle cx="350" cy="30" r="0.9" opacity="0.7"/>
      <circle cx="380" cy="12" r="0.6" opacity="0.5"/>
      <circle cx="30" cy="55" r="0.7" opacity="0.4"/>
      <circle cx="370" cy="65" r="0.7" opacity="0.5"/>
      <circle cx="90" cy="45" r="0.8" opacity="0.6"/>
      <circle cx="310" cy="48" r="0.7" opacity="0.5"/>
    </g>
    <!-- Earth hemisphere (lower portion) -->
    <g clip-path={`url(#clipcirc-${uid})`}>
      <circle cx="200" cy="310" r="185" fill="#0c2240"/>
      <circle cx="200" cy="310" r="185" fill={`url(#earthglow-${uid})`}/>
      <!-- Meridians & parallels -->
      <g fill="none" stroke="#7ea8d8" stroke-width="0.5" stroke-opacity="0.45">
        <ellipse cx="200" cy="310" rx="185" ry="65"/>
        <ellipse cx="200" cy="310" rx="185" ry="115"/>
        <ellipse cx="200" cy="310" rx="65" ry="185"/>
        <ellipse cx="200" cy="310" rx="115" ry="185"/>
        <ellipse cx="200" cy="310" rx="160" ry="185"/>
        <circle cx="200" cy="310" r="185"/>
      </g>
      <!-- Continent dots -->
      <g fill="#8ab8d8" opacity="0.6">
        <circle cx="105" cy="148" r="1.8"/><circle cx="118" cy="140" r="1.5"/><circle cx="128" cy="155" r="1.3"/>
        <circle cx="145" cy="135" r="1.6"/><circle cx="160" cy="142" r="1.4"/><circle cx="152" cy="158" r="1.2"/>
        <circle cx="175" cy="130" r="1.7"/><circle cx="190" cy="138" r="1.5"/>
        <circle cx="225" cy="128" r="1.8"/><circle cx="240" cy="142" r="1.6"/><circle cx="255" cy="135" r="1.4"/>
        <circle cx="270" cy="148" r="1.5"/><circle cx="285" cy="140" r="1.3"/>
        <circle cx="215" cy="155" r="1.4"/><circle cx="205" cy="145" r="1.2"/>
      </g>
    </g>
    <!-- City ping: US West -->
    <g>
      <circle cx="95" cy="140" r="3.5" fill="#6fa3e0" opacity="0.9"/>
      <circle cx="95" cy="140" r="8" fill="none" stroke="#6fa3e0" stroke-width="0.8" stroke-opacity="0.5"/>
      <circle cx="95" cy="140" r="14" fill="none" stroke="#6fa3e0" stroke-width="0.5" stroke-opacity="0.25"/>
    </g>
    <!-- City ping: Europe -->
    <g>
      <circle cx="230" cy="120" r="3.5" fill="#f5d98b" opacity="0.9"/>
      <circle cx="230" cy="120" r="8" fill="none" stroke="#f5d98b" stroke-width="0.8" stroke-opacity="0.5"/>
      <circle cx="230" cy="120" r="14" fill="none" stroke="#f5d98b" stroke-width="0.5" stroke-opacity="0.25"/>
    </g>
    <!-- City ping: Brazil -->
    <g>
      <circle cx="168" cy="158" r="3" fill="#a0c4e8" opacity="0.85"/>
      <circle cx="168" cy="158" r="7" fill="none" stroke="#a0c4e8" stroke-width="0.7" stroke-opacity="0.45"/>
    </g>
    <!-- Arcs -->
    <path d="M 95 140 Q 160 -20 230 120" fill="none" stroke={`url(#arc1-${uid})`} stroke-width="1.8"/>
    <path d="M 95 140 Q 130 50 168 158" fill="none" stroke={`url(#arc2-${uid})`} stroke-width="1.2" stroke-dasharray="4 5"/>
    <path d="M 168 158 Q 210 55 230 120" fill="none" stroke="#6fa3e0" stroke-width="1" stroke-opacity="0.4" stroke-dasharray="3 5"/>
    <!-- Atmosphere horizon glow -->
    <rect x="0" y="125" width="400" height="4" fill="#3e78c0" opacity="0.12" filter="url(#softblur)"/>
    <!-- Label chip -->
    <rect x="14" y="14" width="82" height="16" rx="4" fill="#0a1a2f" fill-opacity="0.85" stroke="#6fa3e0" stroke-width="0.7" stroke-opacity="0.6"/>
    <circle cx="24" cy="22" r="2.5" fill="#6fa3e0"/>
    <rect x="31" y="19" width="56" height="6" rx="1.5" fill="#a0c4e8" fill-opacity="0.6"/>
    <!-- Plane icon top-right -->
    <g transform="translate(295 48) rotate(22)" fill="none" stroke="#f5d98b" stroke-width="1.2" stroke-linecap="round">
      <path d="M-10 0 L12 0 L7 -4 M12 0 L7 4"/>
      <line x1="-4" y1="0" x2="-4" y2="-7"/>
      <line x1="-4" y1="0" x2="-4" y2="7"/>
    </g>
  </svg>
)}

{kind === 'funil' && (
  <svg viewBox="0 0 400 225" preserveAspectRatio="xMidYMid slice" class={`absolute inset-0 h-full w-full ${cls}`} aria-hidden="true">
    <defs>
      <linearGradient id={`bg-${uid}`} x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#1a1205"/>
        <stop offset="55%" stop-color="#121520"/>
        <stop offset="100%" stop-color="#040c16"/>
      </linearGradient>
      <linearGradient id={`funnel-body-${uid}`} x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#f5d98b" stop-opacity="0.22"/>
        <stop offset="100%" stop-color="#c9923a" stop-opacity="0.06"/>
      </linearGradient>
      <linearGradient id={`funnel-left-${uid}`} x1="100%" y1="0%" x2="0%" y2="0%">
        <stop offset="0%" stop-color="#e7be6a" stop-opacity="0.35"/>
        <stop offset="100%" stop-color="#8a5a18" stop-opacity="0.1"/>
      </linearGradient>
      <linearGradient id={`coin-${uid}`} x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#f5d98b"/>
        <stop offset="100%" stop-color="#c9923a"/>
      </linearGradient>
      <radialGradient id={`goldglow-${uid}`} cx="50%" cy="70%" r="55%">
        <stop offset="0%" stop-color="#e7be6a" stop-opacity="0.2"/>
        <stop offset="100%" stop-color="#c9923a" stop-opacity="0"/>
      </radialGradient>
      <filter id={`coinblur-${uid}`}><feGaussianBlur stdDeviation="2.5"/></filter>
    </defs>
    <rect width="400" height="225" fill={`url(#bg-${uid})`}/>
    <rect width="400" height="225" fill={`url(#goldglow-${uid})`}/>
    <!-- Incoming offer cards at top -->
    <!-- Card 1 -->
    <g>
      <rect x="38" y="12" width="72" height="34" rx="5" fill="#0c1a2e" stroke="#6fa3e0" stroke-width="0.8" stroke-opacity="0.7"/>
      <rect x="46" y="19" width="50" height="5" rx="2" fill="#6fa3e0" fill-opacity="0.65"/>
      <rect x="46" y="27" width="34" height="4" rx="1.5" fill="#a0c4e8" fill-opacity="0.4"/>
      <circle cx="50" cy="38" r="3" fill="#1e4e7a"/>
    </g>
    <!-- Card 2 -->
    <g>
      <rect x="164" y="8" width="72" height="34" rx="5" fill="#0c1a2e" stroke="#a0c4e8" stroke-width="0.8" stroke-opacity="0.65"/>
      <rect x="172" y="15" width="50" height="5" rx="2" fill="#a0c4e8" fill-opacity="0.65"/>
      <rect x="172" y="23" width="34" height="4" rx="1.5" fill="#a0c4e8" fill-opacity="0.4"/>
      <rect x="172" y="30" width="22" height="4" rx="1.5" fill="#a0c4e8" fill-opacity="0.25"/>
    </g>
    <!-- Card 3 -->
    <g>
      <rect x="290" y="12" width="72" height="34" rx="5" fill="#1c1206" stroke="#e7be6a" stroke-width="0.8" stroke-opacity="0.65"/>
      <rect x="298" y="19" width="50" height="5" rx="2" fill="#f5d98b" fill-opacity="0.65"/>
      <rect x="298" y="27" width="34" height="4" rx="1.5" fill="#e7be6a" fill-opacity="0.4"/>
    </g>
    <!-- Dashed lines from cards to funnel -->
    <g stroke-width="1" stroke-linecap="round" fill="none" stroke-dasharray="3 5">
