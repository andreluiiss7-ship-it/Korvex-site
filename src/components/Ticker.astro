---
const items = [
  'Pix D0', 'Checkout premium', '135+ moedas', 'Upsell one-click',
  'Área de membros', 'Funil visual', 'Multiadquirência', '7 checkouts diferentes',
  'Vendas globais', 'Saque no mesmo dia', 'Coprodução', 'Suporte humano',
];
const doubled = [...items, ...items];
---

<div class="relative overflow-hidden border-y border-suede-500/10 bg-ink/30 py-3">
  <div
    class="flex w-max items-center"
    style="animation: ticker-korvex 38s linear infinite; white-space: nowrap;"
  >
    {doubled.map((item) => (
      <span
        class="inline-flex shrink-0 items-center gap-3 px-7 text-[11px] font-semibold uppercase tracking-widest text-chrome-300/50"
        style="letter-spacing: 0.18em;"
      >
        <span class="inline-block h-1 w-1 shrink-0 rounded-full bg-titan-400/55"></span>
        {item}
      </span>
    ))}
  </div>
</div>

<style is:global>
  @keyframes ticker-korvex {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
