---
const items = [
  'Pix D0', 'Checkout premium', '135+ moedas', 'Upsell one-click',
  'Área de membros', 'Funil visual', 'Multiadquirência', '7 checkouts diferentes',
  'Vendas globais', 'Saque no mesmo dia', 'Coprodução', 'Suporte humano',
];
const doubled = [...items, ...items];
---

<div class="ticker-wrap relative overflow-hidden border-y border-suede-500/10 bg-ink/30 py-3">
  <div
    class="ticker-track flex w-max items-center"
    style="animation: ticker-korvex 38s linear infinite; white-space: nowrap;"
  >
    {doubled.map((item) => (
      <span
        class="inline-flex shrink-0 items-baseline px-6 font-mono text-[11px] font-semibold uppercase text-chrome-300/65"
        style="letter-spacing: 0.16em;"
      >
        <span class="mr-2 text-titan-400/45">[</span>
        {item}
        <span class="ml-2 text-titan-400/45">]</span>
      </span>
    ))}
  </div>
</div>

<style is:global>
  @keyframes ticker-korvex {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  /* Pausa no hover — convida a ler */
  .ticker-wrap:hover .ticker-track { animation-play-state: paused !important; }
</style>
