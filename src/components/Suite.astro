---
import { icon } from '../lib/icons';

const types = [
  { icon: 'play',    label: 'Curso gravado', desc: 'Módulos, aulas e área de membros.' },
  { icon: 'headset', label: 'Mentoria',      desc: 'Presencial ou online, com área privada.' },
  { icon: 'users',   label: 'Comunidade',    desc: 'Assinatura recorrente com área exclusiva.' },
  { icon: 'ticket',  label: 'Evento',        desc: 'Ingressos, lotes e check-in digital.' },
  { icon: 'repeat',  label: 'Assinatura',    desc: 'Cobrança automática, menos inadimplência.' },
  { icon: 'globe',   label: 'Produto global',desc: 'Venda em qualquer moeda, em qualquer país.' },
];

const specs = [
  { icon: 'repeat', title: 'Recorrência',     desc: 'Assinaturas com cobrança automática.' },
  { icon: 'users',  title: 'Coprodução',      desc: 'Split automático entre parceiros.' },
  { icon: 'link',   title: 'Domínio próprio', desc: 'Checkout no seu domínio.' },
  { icon: 'pix',    title: 'Pix automático',  desc: 'Identificado e baixado na hora.' },
  { icon: 'ticket', title: 'Ingressos',       desc: 'Eventos com lotes e check-in.' },
  { icon: 'clock',  title: 'Tempo real',      desc: 'Cada venda e saque ao vivo.' },
];
---

<section id="tipos" class="relative py-16 sm:py-20">
  <div class="section">
    <!-- header — split editorial -->
    <div class="reveal grid items-end gap-6 border-b border-suede-500/12 pb-8 lg:grid-cols-[1.3fr_1fr]">
      <div>
        <span class="kicker">O que você vende?</span>
        <h2 class="h-display mt-5 text-3xl leading-[1.04] sm:text-[2.6rem]">
          Curso, mentoria, evento.<br class="hidden sm:block" />
          <span class="font-display font-black">Tanto faz.</span>
        </h2>
      </div>
      <p class="max-w-md text-pretty leading-relaxed text-chrome-300/72 lg:text-right">
        Não importa o formato. A estrutura é a mesma — e <strong class="text-white">6 recursos a mais</strong> já vêm dentro, sem custo extra.
      </p>
    </div>

    <!-- product types — 6 chips compactos -->
    <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
      {types.map((t, i) => (
        <div class="reveal mag-card spotlight card group flex flex-col gap-3 p-5 transition-colors hover:border-titan-500/35" style={`transition-delay:${i * 40}ms`}>
          <span class="flex h-9 w-9 items-center justify-center rounded-lg border border-suede-500/20 bg-titan-600/10 p-2 text-titan-400 transition-colors group-hover:text-white" set:html={icon(t.icon)}></span>
          <div>
            <p class="font-display text-[13px] font-semibold text-white">{t.label}</p>
            <p class="mt-0.5 text-[11px] leading-snug text-chrome-300/55">{t.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- specs — 6 quick features -->
    <div class="mt-10 border-t border-suede-500/12 pt-8">
      <div class="reveal mb-6 flex items-end justify-between gap-4">
        <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-chrome-300/55">+6 recursos · sem custo extra</p>
        <p class="hidden text-[11px] text-chrome-300/40 sm:block">tudo dentro do mesmo gateway</p>
      </div>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
        {specs.map((f, i) => (
          <div class="reveal spotlight card flex items-center gap-3 p-4 transition-colors hover:border-titan-500/40" style={`transition-delay:${i * 40}ms`}>
            <span class="flex h-9 w-9 flex-none items-center justify-center rounded-lg border border-suede-500/20 bg-white/[0.03] p-2 text-titan-400" set:html={icon(f.icon)}></span>
            <div class="min-w-0">
              <h4 class="font-display text-[13px] font-semibold leading-tight text-white">{f.title}</h4>
              <p class="mt-0.5 text-[11px] leading-snug text-chrome-300/55">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
