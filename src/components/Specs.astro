---
import { icon } from '../lib/icons';

const items = [
  { icon: 'repeat', title: 'Recorrência', desc: 'Assinaturas com cobrança automática e menos inadimplência.' },
  { icon: 'users', title: 'Coprodução', desc: 'Split automático entre coprodutores e parceiros.' },
  { icon: 'link', title: 'Domínio próprio', desc: 'Checkout no seu domínio: confiança que aprova mais.' },
  { icon: 'pix', title: 'Pix automático', desc: 'Identificado e baixado na hora, sem conferência manual.' },
  { icon: 'ticket', title: 'Ingressos', desc: 'Eventos com lotes, ingressos e check-in.' },
  { icon: 'clock', title: 'Monitoramento ao vivo', desc: 'Cada venda, saque e métrica em tempo real.' },
];
---

<section id="recursos" class="relative py-20 sm:py-24">
  <div class="section">
    <div class="reveal mx-auto max-w-2xl text-center">
      <span class="kicker justify-center">+ tudo o que sua operação precisa</span>
      <h2 class="h-display mt-5 text-3xl leading-[1.08] sm:text-4xl">
        Sem terceiros, sem gambiarra, <span class="text-titan-gradient">sem perder o fio.</span>
      </h2>
    </div>

    <div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
      {items.map((f) => (
        <div class="spotlight card group flex flex-col gap-3 p-5 transition-colors hover:border-titan-500/40">
          <span class="h-8 w-8 text-suede-300 transition-colors group-hover:text-titan-400" set:html={icon(f.icon)}></span>
          <div>
            <h4 class="font-display text-sm font-semibold text-white">{f.title}</h4>
            <p class="mt-1 text-[12px] leading-snug text-chrome-300/55">{f.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
