---
// Faixa de conformidade — sinais de confiança críticos pra gateway
const trust = [
  { k: 'PCI-DSS',      v: 'Nível 1' },
  { k: 'BACEN',        v: 'Conformidade' },
  { k: 'ISO 27001',    v: 'Certificado' },
  { k: 'Antifraude',   v: 'KYT proprietário' },
  { k: 'Liquidação',   v: 'banco parceiro' },
  { k: 'Auditoria',    v: 'trimestral' },
];
---

<section class="relative py-6 sm:py-8">
  <div class="section">
    <div class="reveal rounded-2xl border border-suede-500/12 bg-white/[0.012] px-5 py-5 sm:px-7 sm:py-6">
      <p class="mb-4 text-center text-[10px] font-bold uppercase tracking-[0.22em] text-chrome-300/60 font-mono">
        <span class="inline-block h-1 w-1 align-middle rounded-full bg-chrome-300/55"></span>
        Conformidade · Segurança · Liquidação
      </p>
      <div class="flex flex-wrap items-center justify-center gap-x-7 gap-y-3 sm:gap-x-10">
        {trust.map((t, i) => (
          <>
            {i > 0 && <span class="hidden h-3 w-px bg-suede-500/18 sm:block"></span>}
            <div class="flex items-baseline gap-1.5">
              <span class="text-[12.5px] font-bold tracking-[0.04em] text-white">{t.k}</span>
              <span class="text-[10px] uppercase tracking-[0.14em] text-chrome-300/60 font-mono">{t.v}</span>
            </div>
          </>
        ))}
      </div>
    </div>
  </div>
</section>
