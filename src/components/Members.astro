---
import { icon } from '../lib/icons';
import { REGISTER_URL } from '../lib/site';
---

<section id="membros" class="relative py-16 sm:py-20">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div data-parallax="0.1" class="ambient-drift absolute left-1/2 top-1/3 h-[460px] w-[840px] max-w-[110vw] -translate-x-1/2 rounded-full bg-titan-600/10 blur-[150px]"></div>
  </div>

  <div class="section">
    <!-- header — clean editorial split -->
    <div class="reveal grid items-end gap-6 lg:grid-cols-[1.3fr_1fr]">
      <div>
        <h2 class="h-display mt-5 text-3xl leading-[1.04] sm:text-[2.8rem]">
          Cara de streaming.<br />
          <span class="font-editorial italic font-normal text-titan-gradient">Vende de novo lá dentro.</span>
        </h2>
      </div>
      <p class="max-w-md text-pretty leading-relaxed text-chrome-300/72">
        Seu aluno entra, sente que comprou de uma marca grande,
        e <strong class="text-white">você vende de novo lá dentro</strong> — com +47% de recompra interna.
      </p>
    </div>

    <!-- THE DEVICE — imagem real com moldura premium + floating accents -->
    <div data-tilt-zone class="reveal relative mx-auto mt-12 max-w-6xl">
      <!-- ambient glow atrás da imagem -->
      <div class="pointer-events-none absolute -inset-6 -z-10 rounded-[32px] bg-gradient-to-tr from-titan-600/25 via-transparent to-gold-600/10 blur-3xl"></div>

      <!-- moldura do browser -->
      <div data-tilt="4" class="tilt beam browser overflow-hidden">
        <div class="browser-bar">
          <span class="dot bg-[#ff5f57]/80"></span>
          <span class="dot bg-[#febc2e]/80"></span>
          <span class="dot bg-[#28c840]/80"></span>
          <span class="ml-3 rounded-md bg-white/5 px-2.5 py-1 text-[11px] text-chrome-300/70">alunos.7dglobal.com</span>
          <span class="ml-auto hidden items-center gap-1.5 text-[10px] text-emerald-400 sm:flex">
            <span class="relative flex h-1.5 w-1.5">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
            </span>
            ao vivo
          </span>
        </div>
        <img
          src="/assets/members-dashboard.jpg"
          alt="Área de membros da Mentoria 7D Global hospedada na Korvex"
          class="block w-full"
          loading="lazy"
          width="2000"
          height="1125"
        />
      </div>

      <!-- Floating accent 1: "1.247 alunos online" (top-right) -->
      <div class="absolute z-20 animate-floaty top-2 right-2 lg:top-[-18px] lg:right-[-50px]">
        <div class="rounded-2xl border border-emerald-500/30 bg-ink/95 px-3.5 py-2.5 shadow-glow backdrop-blur-xl">
          <div class="flex items-center gap-2.5">
            <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-emerald-500/15 text-emerald-400" set:html={icon('users')}></span>
            <div>
              <p class="font-display text-sm font-bold leading-none text-white" style="font-feature-settings:'tnum';">1.247</p>
              <p class="mt-0.5 text-[10px] text-chrome-300/70">alunos online agora</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Floating accent 2: "Upsell vendido +R$497" (bottom-left) -->
      <div class="absolute z-20 animate-floaty -bottom-3 left-2 lg:bottom-[-12px] lg:left-[-50px]" style="animation-delay:1.2s">
        <div class="rounded-2xl border border-gold-600/35 bg-ink/95 px-3.5 py-2.5 shadow-gold backdrop-blur-xl">
          <div class="flex items-center gap-2.5">
            <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-gold-600/15 text-gold-300" set:html={icon('spark')}></span>
            <div>
              <p class="font-display text-sm font-bold leading-none text-white">+R$ 497</p>
              <p class="mt-0.5 text-[10px] text-gold-300">Upsell vendido na área</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Floating accent 3: "+47% recompra" (mid-right) -->
      <div class="absolute hidden xl:flex animate-floaty" style="top:42%; right:-40px; animation-delay:0.6s">
        <div class="rounded-2xl border border-titan-500/35 bg-ink/95 px-3.5 py-2.5 shadow-glow backdrop-blur-xl">
          <div class="flex items-center gap-2.5">
            <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-titan-600/15 text-titan-400">
              <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 17l6-6 4 4 8-8" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 7h7v7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <div>
              <p class="font-display text-sm font-bold leading-none text-white">+47%</p>
              <p class="mt-0.5 text-[10px] text-titan-400">recompra interna</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Floating accent 4: certificate (mid-left) -->
      <div class="absolute hidden xl:flex animate-floaty" style="top:30%; left:-32px; animation-delay:1.8s">
        <div class="rounded-2xl border border-suede-500/35 bg-ink/95 px-3.5 py-2.5 shadow-glow backdrop-blur-xl">
          <div class="flex items-center gap-2.5">
            <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-purple-500/15 text-purple-300">
              <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="9" r="5"/><path d="M9 13l-2 7 5-3 5 3-2-7"/></svg>
            </span>
            <div>
              <p class="font-display text-sm font-bold leading-none text-white">Certificado</p>
              <p class="mt-0.5 text-[10px] text-purple-300/80">emitido · 2s</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- compact band + CTA -->
    <div class="reveal mx-auto mt-10 flex max-w-3xl flex-col items-center justify-between gap-4 rounded-2xl border border-suede-500/15 bg-white/[0.02] px-6 py-5 sm:flex-row">
      <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1.5 text-[12px] text-chrome-300/75 sm:justify-start">
        <span class="inline-flex items-center gap-1.5"><span class="h-1 w-1 rounded-full bg-titan-400"></span>Streaming premium</span>
        <span class="inline-flex items-center gap-1.5"><span class="h-1 w-1 rounded-full bg-titan-400"></span>Upsell interno</span>
        <span class="inline-flex items-center gap-1.5"><span class="h-1 w-1 rounded-full bg-titan-400"></span>Domínio próprio</span>
      </div>
      <a href={REGISTER_URL} target="_blank" rel="noopener" class="btn btn-primary magnetic flex-none">
        Quero essa área
        <span class="h-4 w-4" set:html={icon('arrow')}></span>
      </a>
    </div>
  </div>
</section>
