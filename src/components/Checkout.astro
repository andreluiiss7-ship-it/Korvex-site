---
import { icon } from '../lib/icons';
import { REGISTER_URL } from '../lib/site';

// 7 temas REAIS de checkout da Korvex
const themes = [
  { key: 'padrao',    name: 'Padrão',           note: 'Layout clean em 2 colunas. Resumo direita, pagamento esquerda.', tag: 'Mais usado' },
  { key: 'longo',     name: 'Formulário longo', note: 'Tudo vertical, ideal pra carta de vendas + checkout junto.',     tag: 'Long-form' },
  { key: 'box',       name: 'Box',              note: 'Card central focado. Menos distração, mais foco no botão.',     tag: 'Foco' },
  { key: 'moderno',   name: 'Moderno',          note: 'Visual editorial com imagem e destaque pra prova social.',       tag: 'Premium' },
  { key: 'classico',  name: 'Clássico',         note: 'Estilo tradicional, máxima familiaridade pro comprador.',        tag: 'Conversão' },
  { key: 'fluxo',     name: 'Fluxo',            note: 'Conduzido por blocos. Cada bloco abre o próximo na mesma tela.', tag: 'Smart' },
  { key: 'etapas',    name: 'Fluxo (Etapas)',   note: 'Steps clássicos: dados → pagamento → confirmação. Menos chargeback.', tag: 'Multi-step' },
];

const customizable = [
  'Cores, fontes, logo e identidade visual da sua marca',
  'Campos, ordem, order bump, prova social e selos',
  'Timer, depoimentos, garantia e gatilhos de conversão',
  'Domínio próprio — o checkout é seu, não da plataforma',
];
---

<section id="checkout" class="relative py-16 sm:py-20">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute left-1/2 top-1/4 h-[440px] w-[760px] -translate-x-1/2 rounded-full bg-titan-600/10 blur-[140px]"></div>
  </div>

  <div class="section">
    <!-- header — split: headline left, copy right, with inline serif accent -->
    <div class="reveal grid items-end gap-8 border-b border-suede-500/12 pb-10 lg:grid-cols-[1.15fr_0.85fr]">
      <div>
        <span class="chapter">02 · Checkout</span>
        <h2 class="h-display mt-6 text-4xl leading-[1.0] sm:text-[3.2rem]">
          7 checkouts.<br />
          Um <span class="font-display font-black text-chrome-300/75">pra cada oferta.</span>
        </h2>
      </div>
      <p class="max-w-md text-pretty text-lg leading-relaxed text-chrome-300/72">
        Cada tema é uma estrutura própria — do tradicional ao fluxo em etapas —
        e <strong class="text-white">todos 100% personalizáveis</strong> com a sua marca.
      </p>
    </div>

    <!-- THEME SELECTOR — chips na linguagem bracket do logo -->
    <div class="reveal mt-12 mx-auto max-w-5xl">
      <div class="flex flex-wrap items-center justify-center gap-x-1 gap-y-2 sm:gap-x-2">
        {themes.map((t, i) => (
          <button data-ck={t.key} class={`ck-tab${i === 0 ? ' active' : ''}`}>
            <span class="ck-br">[</span><span class="ck-label">{t.name}</span><span class="ck-br">]</span>
          </button>
        ))}
      </div>
      <p class="mt-4 text-center text-[12px] text-chrome-300/60">Clique em um tema — a estrutura do checkout muda de verdade.</p>
    </div>

    <div data-tilt-zone class="mt-10 grid items-start gap-10 lg:grid-cols-[1.15fr_0.85fr]">
      <!-- LEFT: live preview that changes structure -->
      <div class="reveal">
        <div data-tilt="5" class="tilt browser kframe relative">
          <div class="browser-bar">
            <span class="dot bg-[#ff5f57]/80"></span>
            <span class="dot bg-[#febc2e]/80"></span>
            <span class="dot bg-[#28c840]/80"></span>
            <span class="ml-3 rounded-md bg-white/5 px-2.5 py-1 text-[11px] text-chrome-300/70">pay.suamarca.com</span>
            <span class="ml-auto hidden items-center gap-1.5 text-[10px] text-emerald-400 sm:flex">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
              <span data-current-theme>Tema Padrão</span>
            </span>
          </div>

          <!-- VARIANT: padrão (2 colunas) -->
          <div data-view="padrao" class="grid gap-0 sm:grid-cols-[1.2fr_1fr]">
            <div class="border-b border-suede-500/10 p-6 sm:border-b-0 sm:border-r">
              <div class="flex items-center gap-2">
                <div class="h-7 w-7 rounded-lg bg-gradient-to-br from-titan-400 to-titan-600"></div>
                <span class="text-sm font-semibold text-white">Sua Marca</span>
              </div>
              <p class="mt-5 text-[11px] uppercase tracking-wider text-chrome-300/60">Pagamento</p>
              <div class="mt-3 flex gap-2">
                <span class="flex-1 rounded-lg border border-titan-500/60 bg-titan-600/16 px-3 py-2 text-center text-xs font-semibold text-white">Pix</span>
                <span class="flex-1 rounded-lg border border-suede-500/20 px-3 py-2 text-center text-xs text-chrome-300/70">Cartão</span>
                <span class="flex-1 rounded-lg border border-suede-500/20 px-3 py-2 text-center text-xs text-chrome-300/70">Boleto</span>
              </div>
              <div class="mt-4 space-y-2.5">
                <div class="h-9 rounded-lg border border-suede-500/15 bg-white/[0.02]"></div>
                <div class="h-9 rounded-lg border border-suede-500/15 bg-white/[0.02]"></div>
              </div>
              <div class="mt-4 rounded-lg border border-dashed border-titan-500/40 bg-titan-600/[0.06] p-3">
                <div class="flex items-start gap-2">
                  <span class="mt-0.5 flex h-4 w-4 items-center justify-center rounded bg-titan-600 text-white" set:html={icon('check')}></span>
                  <div>
                    <p class="text-[12px] font-semibold text-white">Sim, quero o bônus avançado</p>
                    <p class="text-[11px] text-chrome-300/60">+ R$97 — leve junto com 1 clique</p>
                  </div>
                </div>
              </div>
              <button class="mt-4 w-full rounded-lg bg-gradient-to-b from-titan-400 to-titan-600 py-2.5 text-sm font-semibold text-white shadow-glow">Pagar agora</button>
            </div>
            <div class="bg-white/[0.015] p-6">
              <p class="text-[11px] uppercase tracking-wider text-chrome-300/60">Sua compra</p>
              <div class="mt-3 flex items-center gap-3">
                <div class="h-12 w-12 rounded-lg bg-gradient-to-br from-suede-500 to-navy-800"></div>
                <div>
                  <p class="text-sm font-semibold text-white">Mentoria Escala 7</p>
                  <p class="text-[11px] text-chrome-300/60">Acesso imediato</p>
                </div>
              </div>
              <div class="mt-5 space-y-2 text-[12px] text-chrome-300/70">
                <div class="flex justify-between"><span>Produto</span><span>R$ 1.997</span></div>
                <div class="flex justify-between"><span>Bônus avançado</span><span>R$ 97</span></div>
                <div class="my-2 h-px bg-suede-500/15"></div>
                <div class="flex justify-between text-sm font-semibold text-white"><span>Total</span><span class="text-titan-400">R$ 2.094</span></div>
              </div>
              <div class="mt-5 flex items-center gap-2 rounded-lg border border-suede-500/15 bg-white/[0.02] px-3 py-2 text-[11px] text-chrome-300/65">
                <span class="h-3.5 w-3.5 text-titan-400" set:html={icon('shield')}></span>
                Ambiente seguro e criptografado
              </div>
            </div>
          </div>

          <!-- VARIANT: formulário longo -->
          <div data-view="longo" class="hidden p-6">
            <div class="mx-auto max-w-md">
              <div class="flex items-center gap-2">
                <div class="h-7 w-7 rounded-lg bg-gradient-to-br from-titan-400 to-titan-600"></div>
                <span class="text-sm font-semibold text-white">Sua Marca</span>
              </div>
              <div class="mt-4 rounded-xl border border-suede-500/15 bg-white/[0.02] p-4">
                <p class="text-sm font-semibold text-white">Mentoria Escala 7</p>
                <p class="mt-1 text-[12px] text-chrome-300/65">Acesso vitalício · Bônus inclusos</p>
                <p class="mt-3 font-display text-2xl font-bold text-titan-400">R$ 1.997</p>
              </div>
              <p class="mt-5 text-[11px] uppercase tracking-wider text-chrome-300/60">Seus dados</p>
              <div class="mt-2 space-y-2">
                <div class="h-9 rounded-lg border border-suede-500/15 bg-white/[0.02]"></div>
                <div class="h-9 rounded-lg border border-suede-500/15 bg-white/[0.02]"></div>
                <div class="h-9 rounded-lg border border-suede-500/15 bg-white/[0.02]"></div>
              </div>
              <p class="mt-5 text-[11px] uppercase tracking-wider text-chrome-300/60">Pagamento</p>
              <div class="mt-2 flex gap-2">
                <span class="flex-1 rounded-lg border border-titan-500/60 bg-titan-600/16 px-3 py-2 text-center text-xs font-semibold text-white">Pix</span>
                <span class="flex-1 rounded-lg border border-suede-500/20 px-3 py-2 text-center text-xs text-chrome-300/70">Cartão</span>
              </div>
              <div class="mt-2 space-y-2">
                <div class="h-9 rounded-lg border border-suede-500/15 bg-white/[0.02]"></div>
              </div>
              <button class="mt-5 w-full rounded-lg bg-gradient-to-b from-titan-400 to-titan-600 py-3 text-sm font-bold text-white shadow-glow">Finalizar compra · R$ 1.997</button>
            </div>
          </div>

          <!-- VARIANT: box (card central) -->
          <div data-view="box" class="hidden bg-gradient-to-b from-navy-900/30 to-ink/40 p-8">
            <div class="mx-auto max-w-sm rounded-2xl border border-suede-500/20 bg-ink/95 p-6 shadow-depth backdrop-blur">
              <div class="text-center">
                <div class="mx-auto h-10 w-10 rounded-xl bg-gradient-to-br from-titan-400 to-titan-600"></div>
                <p class="mt-3 text-[11px] uppercase tracking-wider text-chrome-300/60">Finalizar compra</p>
                <p class="font-display text-xl font-bold text-white">Mentoria Escala 7</p>
                <p class="mt-1 font-display text-3xl font-bold text-titan-400">R$ 1.997</p>
              </div>
              <div class="mt-5 space-y-2">
                <div class="h-9 rounded-lg border border-suede-500/15 bg-white/[0.02]"></div>
                <div class="h-9 rounded-lg border border-suede-500/15 bg-white/[0.02]"></div>
              </div>
              <div class="mt-3 flex gap-2">
                <span class="flex-1 rounded-lg border border-titan-500/60 bg-titan-600/16 px-3 py-2 text-center text-xs font-semibold text-white">Pix</span>
                <span class="flex-1 rounded-lg border border-suede-500/20 px-3 py-2 text-center text-xs text-chrome-300/70">Cartão</span>
              </div>
              <button class="mt-4 w-full rounded-lg bg-gradient-to-b from-titan-400 to-titan-600 py-2.5 text-sm font-bold text-white shadow-glow">Pagar com Pix</button>
              <p class="mt-2 text-center text-[10px] text-chrome-300/60">🔒 Compra 100% segura</p>
            </div>
          </div>

          <!-- VARIANT: moderno (editorial premium) -->
          <div data-view="moderno" class="hidden grid gap-0 sm:grid-cols-[1.3fr_1fr]">
            <div class="relative overflow-hidden border-b border-suede-500/10 p-6 sm:border-b-0 sm:border-r">
              <div class="pointer-events-none absolute -top-10 -left-10 h-44 w-44 rounded-full bg-titan-600/20 blur-3xl"></div>
              <div class="relative">
                <div class="flex items-center gap-2"><div class="h-7 w-7 rounded-lg bg-gradient-to-br from-titan-400 to-titan-600"></div><span class="text-sm font-semibold text-white">Sua Marca</span></div>
                <span class="mt-5 inline-flex items-center gap-1.5 rounded-full border border-titan-500/40 bg-titan-600/15 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-titan-300">⚡ Oferta por tempo limitado</span>
                <p class="mt-3 font-display text-2xl font-bold leading-tight text-white">Mentoria Escala 7</p>
                <p class="mt-1 text-[12px] text-chrome-300/65">+1.247 alunos já garantiram</p>
                <div class="mt-4 flex items-center gap-2">
                  <div class="flex -space-x-1.5">
                    <div class="h-6 w-6 rounded-full border-2 border-ink bg-gradient-to-br from-titan-400 to-titan-600"></div>
                    <div class="h-6 w-6 rounded-full border-2 border-ink bg-gradient-to-br from-suede-400 to-navy-700"></div>
                    <div class="h-6 w-6 rounded-full border-2 border-ink bg-gradient-to-br from-gold-400 to-gold-600"></div>
                  </div>
                  <span class="text-[11px] text-chrome-300/65">★★★★★ <strong class="text-white">4.9</strong> (820)</span>
                </div>
                <div class="mt-5 space-y-2">
                  <div class="h-9 rounded-lg border border-suede-500/15 bg-white/[0.02]"></div>
                  <div class="h-9 rounded-lg border border-suede-500/15 bg-white/[0.02]"></div>
                </div>
                <button class="mt-4 w-full rounded-xl bg-gradient-to-b from-titan-400 to-titan-600 py-3 text-sm font-bold text-white shadow-glow">Quero garantir minha vaga →</button>
              </div>
            </div>
            <div class="bg-white/[0.015] p-6">
              <p class="text-[11px] uppercase tracking-wider text-chrome-300/60">Total</p>
              <p class="mt-2 font-display text-3xl font-bold text-white">R$ 1.997</p>
              <p class="text-[11px] text-titan-400">ou 12x R$ 197,40</p>
              <div class="mt-4 space-y-2 text-[11px] text-chrome-300/70">
                <p class="flex items-center gap-2"><span class="h-3 w-3 text-titan-400" set:html={icon('check')}></span>Acesso vitalício</p>
                <p class="flex items-center gap-2"><span class="h-3 w-3 text-titan-400" set:html={icon('check')}></span>3 bônus exclusivos</p>
                <p class="flex items-center gap-2"><span class="h-3 w-3 text-titan-400" set:html={icon('check')}></span>Garantia de 7 dias</p>
              </div>
            </div>
          </div>

          <!-- VARIANT: clássico (table style) -->
          <div data-view="classico" class="hidden p-6">
            <div class="mx-auto max-w-lg">
              <div class="flex items-center justify-center gap-2">
                <div class="h-8 w-8 rounded-lg bg-gradient-to-br from-titan-400 to-titan-600"></div>
                <span class="font-display text-base font-bold text-white">Sua Marca</span>
              </div>
              <h3 class="mt-4 text-center font-display text-lg font-bold text-white">Confirmar pedido</h3>
              <div class="mt-4 rounded-lg border border-suede-500/15 bg-white/[0.02]">
                <div class="flex items-center justify-between border-b border-suede-500/10 p-3 text-[12px]">
                  <span class="text-chrome-300/70">Produto</span><span class="font-semibold text-white">Mentoria Escala 7</span>
                </div>
                <div class="flex items-center justify-between border-b border-suede-500/10 p-3 text-[12px]">
                  <span class="text-chrome-300/70">Subtotal</span><span class="text-white">R$ 1.997,00</span>
                </div>
                <div class="flex items-center justify-between p-3 text-sm">
                  <span class="font-semibold text-white">Total</span><span class="font-bold text-titan-400">R$ 1.997,00</span>
                </div>
              </div>
              <div class="mt-3 grid grid-cols-3 gap-2">
                <span class="rounded border border-titan-500/60 bg-titan-600/16 py-2 text-center text-[11px] font-semibold text-white">Pix</span>
                <span class="rounded border border-suede-500/20 py-2 text-center text-[11px] text-chrome-300/70">Cartão</span>
                <span class="rounded border border-suede-500/20 py-2 text-center text-[11px] text-chrome-300/70">Boleto</span>
              </div>
              <div class="mt-3 space-y-2">
                <div class="h-9 rounded border border-suede-500/15 bg-white/[0.02]"></div>
              </div>
              <button class="mt-3 w-full rounded bg-gradient-to-b from-titan-400 to-titan-600 py-2.5 text-sm font-semibold text-white shadow-glow">Confirmar e pagar</button>
            </div>
          </div>

          <!-- VARIANT: fluxo (blocks expanding) -->
          <div data-view="fluxo" class="hidden p-6">
            <div class="mx-auto max-w-lg space-y-2.5">
              <div class="flex items-center gap-2"><div class="h-7 w-7 rounded-lg bg-gradient-to-br from-titan-400 to-titan-600"></div><span class="text-sm font-semibold text-white">Sua Marca</span></div>
              <div class="rounded-xl border border-suede-500/15 bg-white/[0.02] p-3">
                <div class="flex items-center justify-between"><span class="text-[12px] font-semibold text-white">✓ Identificação</span><span class="text-[10px] text-emerald-400">concluído</span></div>
              </div>
              <div class="rounded-xl border border-titan-500/40 bg-titan-600/[0.08] p-4">
                <div class="mb-3 flex items-center justify-between"><span class="text-[12px] font-semibold text-titan-300">▼ Forma de pagamento</span><span class="text-[10px] text-titan-400/70">em aberto</span></div>
                <div class="flex gap-2">
                  <span class="flex-1 rounded-lg border border-titan-500/60 bg-titan-600/20 px-3 py-2 text-center text-xs font-semibold text-white">Pix</span>
                  <span class="flex-1 rounded-lg border border-suede-500/20 px-3 py-2 text-center text-xs text-chrome-300/70">Cartão</span>
                </div>
                <div class="mt-3 space-y-2">
                  <div class="h-9 rounded-lg border border-suede-500/15 bg-white/[0.02]"></div>
                </div>
                <button class="mt-3 w-full rounded-lg bg-gradient-to-b from-titan-400 to-titan-600 py-2.5 text-sm font-semibold text-white shadow-glow">Continuar para pagamento</button>
              </div>
              <div class="rounded-xl border border-suede-500/15 bg-white/[0.02] p-3 opacity-60">
                <div class="flex items-center justify-between"><span class="text-[12px] text-chrome-300/60">○ Confirmação</span><span class="text-[10px] text-chrome-300/40">aguardando</span></div>
              </div>
            </div>
          </div>

          <!-- VARIANT: fluxo etapas (stepper traditional) -->
          <div data-view="etapas" class="hidden p-6">
            <div class="flex items-center gap-2">
              <div class="flex items-center gap-2 text-[11px] font-semibold">
                <span class="flex h-6 w-6 items-center justify-center rounded-full bg-titan-600/20 text-titan-300 line-through decoration-titan-400/50">1</span>
                <span class="text-chrome-300/60">Identificação</span>
              </div>
              <span class="h-px w-6 bg-suede-500/25"></span>
              <div class="flex items-center gap-2 text-[11px] font-semibold">
                <span class="flex h-6 w-6 items-center justify-center rounded-full bg-titan-500 text-white shadow-glow">2</span>
                <span class="text-white">Pagamento</span>
              </div>
              <span class="h-px w-6 bg-suede-500/15"></span>
              <div class="flex items-center gap-2 text-[11px] font-semibold opacity-50">
                <span class="flex h-6 w-6 items-center justify-center rounded-full border border-suede-500/30 text-chrome-300/60">3</span>
                <span class="text-chrome-300/60">Pronto</span>
              </div>
            </div>
            <div class="mt-6 grid gap-5 sm:grid-cols-[1.3fr_1fr]">
              <div>
                <p class="text-[11px] uppercase tracking-wider text-chrome-300/60">Forma de pagamento</p>
                <div class="mt-3 flex gap-2">
                  <span class="flex-1 rounded-lg border border-suede-500/20 px-3 py-2 text-center text-xs text-chrome-300/70">Pix</span>
                  <span class="flex-1 rounded-lg border border-titan-500/60 bg-titan-600/16 px-3 py-2 text-center text-xs font-semibold text-white">Cartão</span>
                </div>
                <div class="mt-4 space-y-2.5">
                  <div class="h-9 rounded-lg border border-suede-500/15 bg-white/[0.02]"></div>
                  <div class="flex gap-2.5">
                    <div class="h-9 flex-1 rounded-lg border border-suede-500/15 bg-white/[0.02]"></div>
                    <div class="h-9 w-20 rounded-lg border border-suede-500/15 bg-white/[0.02]"></div>
                  </div>
                </div>
                <div class="mt-4 flex items-center gap-2">
                  <button class="flex-1 rounded-lg border border-suede-500/20 py-2.5 text-xs font-semibold text-chrome-300/70">Voltar</button>
                  <button class="flex-[2] rounded-lg bg-gradient-to-b from-titan-400 to-titan-600 py-2.5 text-sm font-semibold text-white shadow-glow">Continuar</button>
                </div>
              </div>
              <div class="rounded-xl border border-suede-500/12 bg-white/[0.02] p-4">
                <p class="text-[11px] uppercase tracking-wider text-chrome-300/60">Resumo</p>
                <p class="mt-2 text-sm font-semibold text-white">Mentoria Escala 7</p>
                <div class="mt-3 flex justify-between text-sm font-semibold text-white"><span>Total</span><span class="text-titan-400">R$ 1.997</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: customization checklist + customizable card -->
      <div class="reveal">
        <div class="card spotlight overflow-hidden p-6 sm:p-7">
          <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-titan-300/80">Personalização total</p>
          <h3 class="h-display mt-4 text-2xl leading-tight">
            Cada tema vira <span class="text-white">a cara da sua marca.</span>
          </h3>
          <p class="mt-3 text-[14px] leading-relaxed text-chrome-300/70">
            O comprador vê a sua operação do começo ao fim — não a de uma plataforma. Mais percepção de marca,
            menos atrito, mais aprovação.
          </p>
          <ul class="mt-5 space-y-2.5">
            {customizable.map((c) => (
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 flex-none items-center justify-center rounded-full bg-titan-600/20 text-titan-400" set:html={icon('check')} />
                <span class="text-[13px] leading-snug text-chrome-200/90">{c}</span>
              </li>
            ))}
          </ul>
          <a href={REGISTER_URL} target="_blank" rel="noopener" class="btn btn-primary magnetic mt-6 w-full justify-center">
            Montar meu checkout
            <span class="h-4 w-4" set:html={icon('arrow')}></span>
          </a>
        </div>

      </div>
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.ck-tab');
  const views = document.querySelectorAll<HTMLElement>('[data-view]');
  const labelEl = document.querySelector<HTMLSpanElement>('[data-current-theme]');
  const labels: Record<string, string> = {
    padrao: 'Tema Padrão',
    longo: 'Formulário longo',
    box: 'Tema Box',
    moderno: 'Tema Moderno',
    classico: 'Tema Clássico',
    fluxo: 'Tema Fluxo',
    etapas: 'Fluxo em Etapas',
  };
  let busy = false;
  tabs.forEach((t) => {
    t.addEventListener('click', () => {
      if (busy || t.classList.contains('active')) return;
      busy = true;
      const key = t.dataset.ck!;
      tabs.forEach((x) => x.classList.toggle('active', x === t));
      // fade-out → troca de estrutura → fade-in
      const visible = [...views].find((el) => !el.classList.contains('hidden'));
      const next = [...views].find((el) => el.dataset.view === key);
      const swap = () => {
        views.forEach((el) => el.classList.toggle('hidden', el.dataset.view !== key));
        if (labelEl) labelEl.textContent = labels[key] || 'Tema';
        if (next) {
          next.style.opacity = '0';
          next.style.transform = 'translateY(6px)';
          requestAnimationFrame(() => {
            next.style.transition = 'opacity .35s ease, transform .35s cubic-bezier(0.16,1,0.3,1)';
            next.style.opacity = '1';
            next.style.transform = 'none';
            setTimeout(() => { next.style.transition = ''; busy = false; }, 380);
          });
        } else { busy = false; }
      };
      if (visible) {
        visible.style.transition = 'opacity .18s ease';
        visible.style.opacity = '0';
        setTimeout(() => { visible.style.opacity = ''; visible.style.transition = ''; swap(); }, 180);
      } else swap();
    });
  });
</script>

